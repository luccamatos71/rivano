---
type Props = {
  productName: string;
  className?: string;
};

const { productName, className = "" } = Astro.props as Props;
const phone = "5571993135522";
const message = `Olá! Tenho interesse no ${productName}.`;
const href = `https://wa.me/${phone}?text=${encodeURIComponent(message)}`;
---

<a
  href={href}
  class={`primary-button ${className}`.trim()}
  target="_blank"
  rel="noopener noreferrer"
  aria-label={`Pedir ${productName} pelo WhatsApp`}
>
  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path
      d="M20.52 3.48A11.85 11.85 0 0 0 12.08 0C5.56 0 .27 5.3.27 11.82c0 2.09.55 4.14 1.58 5.94L0 24l6.43-1.79a11.77 11.77 0 0 0 5.64 1.44h.01c6.52 0 11.82-5.3 11.82-11.82a11.76 11.76 0 0 0-3.38-8.35Zm-8.44 18.2h-.01a9.84 9.84 0 0 1-5.01-1.37l-.36-.21-3.81 1.06 1.02-3.72-.23-.38a9.84 9.84 0 0 1-1.51-5.23c0-5.44 4.43-9.86 9.88-9.86a9.8 9.8 0 0 1 6.99 2.9 9.8 9.8 0 0 1 2.89 6.96c0 5.45-4.43 9.86-9.86 9.86Zm5.41-7.39c-.29-.15-1.72-.85-1.99-.95-.26-.1-.46-.15-.65.15-.19.29-.75.95-.92 1.14-.17.2-.34.22-.63.07-.29-.15-1.23-.45-2.34-1.44-.86-.76-1.44-1.7-1.61-1.99-.17-.29-.02-.45.12-.59.13-.12.29-.32.44-.49.15-.17.19-.29.29-.49.1-.2.05-.37-.02-.52-.08-.15-.66-1.6-.91-2.19-.24-.58-.49-.5-.65-.5h-.56c-.2 0-.51.08-.78.37-.27.29-1.03 1-.1 2.43.92 1.43 2.1 2.8 4.93 3.92.67.29 1.19.46 1.6.58.67.21 1.28.18 1.76.11.54-.08 1.72-.7 1.97-1.38.24-.68.24-1.26.17-1.38-.07-.12-.27-.19-.56-.34Z"
    />
  </svg>
  Pedir pelo WhatsApp
</a>
