---
interface ProductCardData {
  slug: string;
  name: string;
  price: number;
  stock?: number;
  image: string;
  hoverImage?: string;
  available?: boolean;
}

interface Props extends Partial<ProductCardData> {
  product?: ProductCardData;
  index?: number;
}

const props = Astro.props as Props;
const source = props.product ?? props;
const { slug = "", name = "", price = 0, stock, image = "", hoverImage, available = true } = source;
const { index = Number.MAX_SAFE_INTEGER } = props;
const productLink = `/produtos/${slug}`;
const formattedPrice = `R$ ${price.toFixed(2).replace(".", ",")}`;
const showLowStockBadge = typeof stock === "number" && stock <= 3;
const imageLoading = index < 4 ? "eager" : "lazy";

function buildImageSrcset(src: string): string {
  const normalized = src.startsWith("/") ? src : `/${src}`;

  if (!/-(?:600|1200|2000)\.webp$/i.test(normalized)) {
    return "";
  }

  return [600, 1200, 2000]
    .map((width) => `${normalized.replace(/-(?:600|1200|2000)\.webp$/i, `-${width}.webp`)} ${width}w`)
    .join(", ");
}
---

<a
  href={productLink}
  class:list={["product-card group block", !available && "opacity-60"]}
  aria-label={`Ver ${name}`}
>
  <div class="image-container relative aspect-[3/4] overflow-hidden bg-[var(--rivano-off-white)]">
    {
      image ? (
        <img
          src={image}
          srcset={buildImageSrcset(image)}
          sizes="(min-width: 1024px) 50vw, 50vw"
          alt={name}
          class:list={[
            "main-image h-full w-full object-contain p-6 transition-opacity duration-slow",
            hoverImage && "group-hover:opacity-0",
          ]}
          loading={imageLoading}
          decoding="async"
          width="900"
          height="1200"
        />
      ) : (
        <div class="flex h-full w-full items-center justify-center bg-[var(--rivano-beige)] text-[11px] uppercase tracking-[0.2em] text-[var(--rivano-muted)]">
          Sem imagem
        </div>
      )
    }

    {
      hoverImage && (
        <img
          src={hoverImage}
          srcset={buildImageSrcset(hoverImage)}
          sizes="(min-width: 1024px) 50vw, 50vw"
          alt={`${name} view 2`}
          class="hover-image absolute inset-0 h-full w-full object-contain p-6 opacity-0 transition-opacity duration-slow group-hover:opacity-100"
          loading={imageLoading}
          decoding="async"
          width="900"
          height="1200"
        />
      )
    }

    {
      showLowStockBadge && (
        <span class="absolute left-3 top-3 bg-[#c0392b] px-2 py-[3px] font-['DM_Sans'] text-[10px] font-normal uppercase tracking-[0.12em] text-[var(--rivano-off-white)]">
          Últimas unidades
        </span>
      )
    }
  </div>

  <div class="product-info mt-3">
    <h3 class="card-name font-['DM_Sans'] text-[14px] font-normal leading-[1.45] text-[var(--rivano-brown)]">{name}</h3>
    <p class="price mt-1 text-[14px] font-light leading-[1.3] text-[var(--rivano-muted)]">{formattedPrice}</p>
    {!available && <p class="mt-1 text-[11px] uppercase tracking-[0.18em] text-[var(--rivano-muted)]">Esgotado</p>}
  </div>
</a>

<style>
  .product-card .image-container {
    box-shadow: 0 2px 8px color-mix(in srgb, var(--rivano-brown) 6%, transparent);
    transition:
      transform 0.5s cubic-bezier(0.16, 1, 0.3, 1),
      box-shadow 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .product-card:hover .image-container {
    box-shadow: 0 18px 44px color-mix(in srgb, var(--rivano-brown) 15%, transparent);
    transform: translateY(-6px);
  }

  .card-name {
    text-decoration: underline;
    text-decoration-color: transparent;
    text-decoration-thickness: 1px;
    text-underline-offset: 3px;
    transition:
      text-decoration-color 0.3s ease-out,
      color 0.25s ease-out;
  }

  .product-card:hover .card-name {
    color: var(--rivano-brown-mid);
    text-decoration-color: color-mix(in srgb, var(--rivano-brown-mid) 60%, transparent);
  }
</style>
