---
interface HeroCta {
  label: string;
  href: string;
  variant: "primary" | "secondary";
}

interface Props {
  imageUrl: string;
  title: string;
  subtitle?: string;
  ctas?: HeroCta[];
}

const { imageUrl, title, subtitle, ctas = [] } = Astro.props as Props;
---

<section class="hero relative flex min-h-[70vh] w-full items-center justify-center overflow-hidden md:h-screen">
  <img
    src={imageUrl}
    alt={title}
    class="hero-image absolute inset-0 z-[1] h-full w-full object-cover"
    loading="eager"
    decoding="async"
  />
  <div class="hero-overlay absolute inset-0 z-[2] bg-[color-mix(in_srgb,var(--rivano-brown)_30%,transparent)]"></div>
  <div class="hero-content page-wrap relative z-[3] text-center text-[var(--rivano-off-white)]">
    <h1 class="display-xl font-['Cormorant_Garamond'] font-normal text-[var(--rivano-off-white)]">
      {title}
    </h1>
    {subtitle && <p class="mx-auto mt-4 max-w-[560px] text-[16px] font-light leading-[1.8]">{subtitle}</p>}
    {
      ctas.length > 0 && (
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          {ctas.map((cta) => (
            <a
              href={cta.href}
              class:list={[
                "btn inline-flex min-h-[54px] items-center justify-center px-8 py-4 text-[13px] font-normal uppercase tracking-[0.1em] transition-colors duration-normal",
                cta.variant === "primary"
                  ? "btn-primary bg-[var(--rivano-brown-mid)] text-[var(--rivano-off-white)] hover:bg-[var(--rivano-brown)]"
                  : "btn-secondary border border-[var(--rivano-off-white)] bg-transparent text-[var(--rivano-off-white)] hover:bg-[var(--rivano-off-white)] hover:text-[var(--rivano-brown)]",
              ]}
            >
              {cta.label}
            </a>
          ))}
        </div>
      )
    }
  </div>
</section>
