---
interface FilterItem {
  label: string;
  value: string;
  count?: number;
}

interface Props {
  filters: FilterItem[];
  activeFilter?: string;
}

const { filters, activeFilter = "all" } = Astro.props as Props;
---

<div class="filter-bar flex gap-4 overflow-x-auto border-b border-[#d8c7ae] px-5 py-6 sm:px-10">
  {
    filters.map((filter) => {
      const isActive = activeFilter === filter.value;

      return (
        <button
          type="button"
          data-filter-button
          data-filter={filter.value}
          class:list={[
            "filter-btn whitespace-nowrap border px-4 py-2 font-['DM_Sans'] text-[12px] font-normal uppercase tracking-[0.12em] transition-colors duration-200",
            isActive
              ? "active border-[#6e5542] bg-[#6e5542] text-[#f5f1e8]"
              : "border-[#3f3028] bg-transparent text-[#3f3028] hover:border-[#6e5542]",
          ]}
          aria-pressed={isActive ? "true" : "false"}
        >
          {filter.label}
          {typeof filter.count === "number" && <span class="ml-2 text-current/70">{filter.count}</span>}
        </button>
      );
    })
  }
</div>
