---
interface FilterItem {
  label: string;
  value: string;
  count?: number;
}

interface Props {
  filters: FilterItem[];
  activeFilter?: string;
  group?: string;
  small?: boolean;
}

const { filters, activeFilter = "all", group = "audience", small = false } = Astro.props as Props;
---

<div class:list={["filter-bar flex gap-3 overflow-x-auto", small ? "mt-3" : "gap-4"]}>
  {
    filters.map((filter) => {
      const isActive = activeFilter === filter.value;

      return (
        <button
          type="button"
          data-filter-button
          data-filter-group={group}
          data-filter={filter.value}
          class:list={[
            "filter-btn whitespace-nowrap border px-4 py-2 font-['DM_Sans'] font-normal uppercase transition-colors duration-normal",
            small ? "text-[11px] tracking-[0.16em]" : "text-[12px] tracking-[0.12em]",
            isActive
              ? "active border-[var(--rivano-brown-mid)] bg-[var(--rivano-brown-mid)] text-[var(--rivano-off-white)]"
              : "border-[var(--rivano-brown)] bg-transparent text-[var(--rivano-brown)] hover:border-[var(--rivano-brown-mid)]",
          ]}
          aria-pressed={isActive ? "true" : "false"}
        >
          {filter.label}
          {typeof filter.count === "number" && <span class="ml-2 text-current/70">{filter.count}</span>}
        </button>
      );
    })
  }
</div>
