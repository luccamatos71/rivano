---
interface Props {
  label?: string;
  phoneNumber?: string;
  variant?: "primary" | "secondary";
  fullWidth?: boolean;
  productName?: string;
}

const {
  label = "Pedir pelo WhatsApp",
  phoneNumber = "5571993135522",
  variant = "primary",
  fullWidth = false,
  productName,
} = Astro.props as Props;

const whatsappMessage = productName
  ? `Olá! 👋 Tenho interesse nos óculos ${productName}. Podem me ajudar com disponibilidade e frete?`
  : "Olá! 👋 Queria saber mais sobre os óculos da Rivano.";
const href = `https://wa.me/${phoneNumber}?text=${encodeURIComponent(whatsappMessage)}`;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class:list={[
    "cta-button inline-flex items-center gap-2 px-8 py-4 font-['DM_Sans'] text-[13px] font-normal uppercase tracking-[0.1em] no-underline transition-colors duration-normal",
    variant === "primary"
      ? "btn-primary border border-[var(--rivano-brown-mid)] bg-[var(--rivano-brown-mid)] text-[var(--rivano-off-white)] hover:border-[var(--rivano-brown)] hover:bg-[var(--rivano-brown)]"
      : "btn-secondary border border-[var(--rivano-brown)] bg-transparent text-[var(--rivano-brown)] hover:bg-[var(--rivano-brown)] hover:text-[var(--rivano-off-white)]",
    fullWidth && "w-full justify-center",
  ]}
  aria-label={label}
>
  <svg class="whatsapp-icon h-[14px] w-[14px]" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.67-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.076 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421-7.403h-.004a9.87 9.87 0 00-4.995 1.348l-.36-.183L2.702 2.56l.855 3.081A9.857 9.857 0 002.5 12c0 5.471 4.585 9.905 10.007 9.905 2.716 0 5.274-.869 7.422-2.49l.362.187 3.099 1.006-.893-3.222a9.9 9.9 0 001.449-5.393c0-5.471-4.585-9.905-10.007-9.905z" />
  </svg>
  {label}
</a>
