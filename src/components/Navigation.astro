---
interface Props {
  logo?: string;
  hasAnnouncementBar?: boolean;
}

const { logo, hasAnnouncementBar = true } = Astro.props as Props;
const pathname = Astro.url.pathname;
const isCatalog = pathname.startsWith("/catalogo") || pathname.startsWith("/produtos/");
---

<header
  class:list={[
    "navbar sticky z-[100] border-b border-[var(--rivano-beige)] bg-[var(--rivano-off-white)] px-5 sm:px-10",
    hasAnnouncementBar ? "top-[48px] sm:top-[32px]" : "top-0",
  ]}
>
  <div class="navbar-content mx-auto flex h-[60px] max-w-[1280px] items-center justify-between sm:grid sm:h-[90px] sm:grid-cols-3">
    <nav class="nav-menu hidden items-center gap-8 sm:flex" aria-label="Coleções">
      <a
        href="/catalogo"
        class:list={[
          "nav-link-slide inline-flex min-h-[44px] items-center font-['DM_Sans'] text-[12px] font-normal uppercase tracking-[0.12em] text-[var(--rivano-brown)]",
          isCatalog && "is-current",
        ]}
      >
        Modelos
      </a>
      <a href="/catalogo?para=ela" class="nav-link-slide inline-flex min-h-[44px] items-center font-['DM_Sans'] text-[12px] font-normal uppercase tracking-[0.12em] text-[var(--rivano-brown)]">
        Para ela
      </a>
    </nav>

    <a href="/" class="flex min-h-[44px] min-w-[104px] items-center sm:justify-center" aria-label="Rivano">
      {
        logo ? (
          <img src={logo} alt="Rivano" class="logo h-10 w-auto" />
        ) : (
          <span class="font-['Cormorant_Garamond'] text-[27px] font-normal uppercase leading-none tracking-[0.16em] text-[var(--rivano-brown)] sm:text-[30px]">
            Rivano
          </span>
        )
      }
    </a>

    <nav class="nav-menu hidden items-center justify-end gap-8 sm:flex" aria-label="Marca">
      <a href="/catalogo?para=ele" class="nav-link-slide inline-flex min-h-[44px] items-center font-['DM_Sans'] text-[12px] font-normal uppercase tracking-[0.12em] text-[var(--rivano-brown)]">
        Para ele
      </a>
      <a href="/#sobre" class="nav-link-slide inline-flex min-h-[44px] items-center font-['DM_Sans'] text-[12px] font-normal uppercase tracking-[0.12em] text-[var(--rivano-brown)]">
        Sobre
      </a>
    </nav>

    <button
      id="nav-menu-toggle"
      type="button"
      class="inline-flex min-h-[44px] items-center font-['DM_Sans'] text-[12px] font-normal uppercase tracking-[0.12em] text-[var(--rivano-brown)] sm:hidden"
      aria-controls="mobile-nav"
      aria-expanded="false"
    >
      Menu
    </button>
  </div>

  <div id="mobile-nav" class="mobile-nav-overlay fixed inset-0 z-[110] sm:hidden" aria-hidden="true">
    <div class="mobile-nav-drawer ml-auto h-full w-[78%] max-w-[330px] bg-[var(--rivano-off-white)] px-6 py-7 shadow-[0_8px_24px_color-mix(in_srgb,var(--rivano-brown)_12%,transparent)]">
      <div class="mb-8 flex items-center justify-between">
        <span class="font-['Cormorant_Garamond'] text-[25px] font-normal uppercase leading-none tracking-[0.16em] text-[var(--rivano-brown)]">
          Rivano
        </span>
        <button id="nav-menu-close" type="button" class="inline-flex min-h-[44px] items-center font-['DM_Sans'] text-[12px] uppercase tracking-[0.12em] text-[var(--rivano-brown)]">
          Fechar
        </button>
      </div>
      <nav class="flex flex-col gap-5" aria-label="Navegação mobile">
        <a href="/catalogo" class="inline-flex min-h-[44px] items-center font-['DM_Sans'] text-[12px] uppercase tracking-[0.12em] text-[var(--rivano-brown)]">Modelos</a>
        <a href="/catalogo?para=ela" class="inline-flex min-h-[44px] items-center font-['DM_Sans'] text-[12px] uppercase tracking-[0.12em] text-[var(--rivano-brown)]">Para ela</a>
        <a href="/catalogo?para=ele" class="inline-flex min-h-[44px] items-center font-['DM_Sans'] text-[12px] uppercase tracking-[0.12em] text-[var(--rivano-brown)]">Para ele</a>
        <a href="/#sobre" class="inline-flex min-h-[44px] items-center font-['DM_Sans'] text-[12px] uppercase tracking-[0.12em] text-[var(--rivano-brown)]">Sobre</a>
      </nav>
    </div>
  </div>
</header>

<script is:inline>
  const navToggleButton = document.getElementById("nav-menu-toggle");
  const navCloseButton = document.getElementById("nav-menu-close");
  const navDrawer = document.getElementById("mobile-nav");

  const closeNavigation = () => {
    if (!navDrawer || !navToggleButton) return;
    navDrawer.setAttribute("aria-hidden", "true");
    navToggleButton.setAttribute("aria-expanded", "false");
    document.body.style.overflow = "";
  };

  const openNavigation = () => {
    if (!navDrawer || !navToggleButton) return;
    navDrawer.setAttribute("aria-hidden", "false");
    navToggleButton.setAttribute("aria-expanded", "true");
    document.body.style.overflow = "hidden";
  };

  navToggleButton?.addEventListener("click", openNavigation);
  navCloseButton?.addEventListener("click", closeNavigation);
  navDrawer?.addEventListener("click", (event) => {
    if (event.target === navDrawer) closeNavigation();
  });
</script>

<style>
  /* Desktop nav underline */
  .nav-link-slide {
    position: relative;
  }

  .nav-link-slide::after {
    content: '';
    position: absolute;
    bottom: 14px;
    left: 0;
    width: 100%;
    height: 1px;
    background: var(--rivano-brown-mid);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.28s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .nav-link-slide:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  .nav-link-slide.is-current::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  /* Mobile nav overlay + slide */
  .mobile-nav-overlay {
    background: color-mix(in srgb, var(--rivano-brown) 18%, transparent);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease-out;
  }

  .mobile-nav-overlay[aria-hidden="false"] {
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-nav-drawer {
    transform: translateX(100%);
    transition: transform 0.38s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .mobile-nav-overlay[aria-hidden="false"] .mobile-nav-drawer {
    transform: translateX(0);
  }
</style>
