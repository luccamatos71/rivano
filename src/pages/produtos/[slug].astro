---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  buildSrcset,
  getImageSets,
  getProductDescription,
  pickRelatedProducts,
  toCardProduct,
  toParagraphs,
  type CardProduct,
  type Product,
} from "../../lib/products";
import productsData from "../../data/products.json";

const allProducts = productsData as Product[];

export function getStaticPaths() {
  const products = productsData as Product[];
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

type VariantWithColor = Product["variants"][number] & {
  color?: string;
  hex?: string;
  value?: string;
};

type DisplayVariant = Product["variants"][number] & {
  colorValue: string;
};

const { product } = Astro.props as { product: Product };
const imageSets = getImageSets(product.images);
const firstImage = imageSets[0];
const relatedProducts = pickRelatedProducts(allProducts, product.slug, 4).map(toCardProduct);
const productDescription = getProductDescription(product);
const formattedPrice = new Intl.NumberFormat("pt-BR", {
  style: "currency",
  currency: "BRL",
  minimumFractionDigits: 2,
  maximumFractionDigits: 2,
}).format(product.price);
const whatsappMessage = `Olá! 👋 Tenho interesse nos óculos ${product.name}. Podem me ajudar com disponibilidade e frete?`;
const whatsappUrl = `https://wa.me/5571993135522?text=${encodeURIComponent(whatsappMessage)}`;
const detailsEntries = Object.entries(product.description.details ?? {});
const sizeGuideLines = sectionLines(product.description.fit);
const selectedVariantIndex =
  product.variants.findIndex((variant) => variant.stock > 0) >= 0
    ? product.variants.findIndex((variant) => variant.stock > 0)
    : 0;
const colorVariants = product.variants
  .map((variant) => {
    const colorValue = getVariantColor(variant as VariantWithColor);
    return colorValue ? { ...variant, colorValue } : null;
  })
  .filter((variant): variant is DisplayVariant => Boolean(variant));

const reviews = [
  {
    quote: "Óculos perfeitos, chegaram rápido e a qualidade surpreendeu.",
    name: "Mariana R.",
    city: "Salvador",
  },
  {
    quote: "Comprei pelo WhatsApp, super fácil. Adoro o design.",
    name: "Pedro A.",
    city: "São Paulo",
  },
  {
    quote: "Já é o segundo par que compro. Não troco por nada.",
    name: "Camila S.",
    city: "Recife",
  },
];

function sectionLines(value: string | null): string[] {
  if (!value) {
    return [];
  }

  return toParagraphs(value).filter((line) => {
    const normalized = line.toLowerCase();
    return normalized !== "rivano experience" && normalized !== "como fica" && normalized !== "detalhes";
  });
}

function normalizeText(value: string): string {
  return value
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .toLowerCase();
}

function getVariantColor(variant: VariantWithColor): string | null {
  const explicitColor = variant.color ?? variant.hex ?? variant.value;

  if (explicitColor) {
    return explicitColor;
  }

  const name = normalizeText(variant.name);

  if (name.includes("clara") || name.includes("transparente")) {
    return "var(--rivano-beige)";
  }

  if (name.includes("escura") || name.includes("preta") || name.includes("grafite")) {
    return "var(--rivano-brown)";
  }

  if (name.includes("marrom") || name.includes("tartaruga")) {
    return "var(--rivano-brown-mid)";
  }

  if (name.includes("dourad")) {
    return "var(--rivano-gold)";
  }

  return null;
}

function relatedImageSrcset(product: CardProduct): string {
  const normalized = product.image.startsWith("/") ? product.image : `/${product.image}`;

  if (!/-(?:600|1200|2000)\.webp$/i.test(normalized)) {
    return "";
  }

  return [600, 1200, 2000]
    .map((width) => `${normalized.replace(/-(?:600|1200|2000)\.webp$/i, `-${width}.webp`)} ${width}w`)
    .join(", ");
}

function formattedRelatedPrice(value: number): string {
  return new Intl.NumberFormat("pt-BR", {
    style: "currency",
    currency: "BRL",
    minimumFractionDigits: 2,
    maximumFractionDigits: 2,
  }).format(value);
}
---

<BaseLayout title={`${product.name} | Rivano`} description={productDescription}>
  <article class="pdp-page">
    <section class="pdp-main" aria-label={`Detalhes de ${product.name}`}>
      <div class="pdp-gallery">
        {imageSets.length > 0 ? (
          <>
            <div class="mobile-gallery" data-carousel aria-label={`Galeria de imagens de ${product.name}`}>
              {imageSets.map((imageSet, index) => (
                <figure class="mobile-slide" data-slide={index}>
                  <img
                    src={`/${imageSet.src}`}
                    srcset={buildSrcset(imageSet)}
                    sizes="100vw"
                    alt={`${product.name} - foto ${index + 1}`}
                    class="mobile-gallery-image"
                    loading={index === 0 ? "eager" : "lazy"}
                    fetchpriority={index === 0 ? "high" : undefined}
                    decoding="async"
                    width="900"
                    height="1200"
                  />
                </figure>
              ))}
            </div>

            {imageSets.length > 1 && (
              <div class="gallery-dots" data-dots>
                {imageSets.map((_, index) => (
                  <button
                    type="button"
                    class="gallery-dot-button"
                    data-dot={index}
                    aria-label={`Mostrar foto ${index + 1}`}
                    aria-current={index === 0 ? "true" : "false"}
                  >
                    <span class:list={["gallery-dot", index === 0 && "is-active"]} data-dot-indicator></span>
                  </button>
                ))}
              </div>
            )}

            <div class="desktop-gallery" aria-label={`Galeria de imagens de ${product.name}`}>
              <figure class="desktop-main-frame">
                <img
                  src={`/${firstImage.src}`}
                  srcset={buildSrcset(firstImage)}
                  sizes="(min-width: 768px) 58vw, 100vw"
                  alt={`${product.name} - foto 1`}
                  class="desktop-main-image"
                  data-main-image
                  loading="eager"
                  fetchpriority="high"
                  decoding="async"
                  width="900"
                  height="1200"
                />
              </figure>

              {imageSets.length > 1 && (
                <div class="thumbnail-row" aria-label="Escolha uma foto">
                  {imageSets.map((imageSet, index) => (
                    <button
                      type="button"
                      class:list={["thumbnail-button", index === 0 && "is-active"]}
                      data-thumb={index}
                      data-thumb-src={`/${imageSet.src}`}
                      data-thumb-srcset={buildSrcset(imageSet)}
                      data-thumb-alt={`${product.name} - foto ${index + 1}`}
                      aria-label={`Ver foto ${index + 1}`}
                      aria-current={index === 0 ? "true" : "false"}
                    >
                      <img
                        src={`/${imageSet.src}`}
                        srcset={buildSrcset(imageSet)}
                        sizes="72px"
                        alt=""
                        class="thumbnail-image"
                        loading={index < 6 ? "eager" : "lazy"}
                        decoding="async"
                        width="144"
                        height="192"
                      />
                    </button>
                  ))}
                </div>
              )}
            </div>
          </>
        ) : (
          <div class="gallery-empty">Imagem indisponível</div>
        )}
      </div>

      <aside class="product-panel">
        <nav class="product-breadcrumb" aria-label="Caminho do produto">
          <a href="/">Início</a>
          <span aria-hidden="true">/</span>
          <a href="/catalogo">Catálogo</a>
          <span aria-hidden="true">/</span>
          <span>{product.name}</span>
        </nav>

        <div class="product-heading">
          <h1 class="display-md product-title">{product.name}</h1>
          <p class="product-price-main">{formattedPrice}</p>
        </div>

        <div class="trust-inline" aria-label="Benefícios">
          <span>↻ Troca 30 dias</span>
          <span class="trust-separator" aria-hidden="true">·</span>
          <span>🚚 Frete grátis</span>
          <span class="trust-separator" aria-hidden="true">·</span>
          <span>✓ Original</span>
        </div>

        {colorVariants.length > 0 && (
          <div class="color-selector" aria-label="Seleção de cor">
            <p class="panel-label">Cor</p>
            <div class="color-options">
              {colorVariants.map((variant, index) => (
                <div class="color-choice">
                  <button
                    type="button"
                    class:list={[
                      "color-option",
                      index === selectedVariantIndex && "is-active",
                      variant.stock <= 0 && "is-disabled",
                    ]}
                    aria-label={`Selecionar ${variant.name}`}
                    aria-pressed={index === selectedVariantIndex ? "true" : "false"}
                    data-color-option
                  >
                    <span class="color-dot" style={`background: ${variant.colorValue};`}></span>
                  </button>
                  <span class="color-name">{variant.name}</span>
                </div>
              ))}
            </div>
          </div>
        )}

        <a class="whatsapp-cta" href={whatsappUrl} data-primary-cta>
          Consultar pelo WhatsApp
        </a>

        <div class="feature-icons" aria-label="Características do produto">
          <div class="feature-icon">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M3 13.5c1-3 3.2-4.8 6.2-4.8 2.6 0 4 1.4 4.8 3.8.8-2.4 2.2-3.8 4.8-3.8 3 0 5.2 1.8 6.2 4.8" />
              <path d="M3 13.5h8.7" />
              <path d="M16.3 13.5H21" />
              <path d="M11.7 13.5a3 3 0 1 1-6 0" />
              <path d="M22.3 13.5a3 3 0 1 1-6 0" />
            </svg>
            <span>Armação leve</span>
          </div>
          <div class="feature-icon">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M20 4c-7 0-12 4.5-12 10.5 0 2.8 2.2 5.5 5.5 5.5C19 20 22 12.5 20 4z" />
              <path d="M5 21c2.8-5.4 6.8-8.8 12-10.2" />
            </svg>
            <span>Material premium</span>
          </div>
          <div class="feature-icon">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="12" cy="12" r="4" />
              <path d="M12 2.5v3" />
              <path d="M12 18.5v3" />
              <path d="M2.5 12h3" />
              <path d="M18.5 12h3" />
              <path d="m5.3 5.3 2.1 2.1" />
              <path d="m16.6 16.6 2.1 2.1" />
              <path d="m18.7 5.3-2.1 2.1" />
              <path d="m7.4 16.6-2.1 2.1" />
            </svg>
            <span>Proteção UV400</span>
          </div>
          <div class="feature-icon">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M12 3 19 6v5.5c0 4.4-2.8 7.7-7 9.5-4.2-1.8-7-5.1-7-9.5V6l7-3z" />
              <path d="m8.7 12.1 2.2 2.2 4.6-4.8" />
            </svg>
            <span>Garantia inclusa</span>
          </div>
        </div>

        <div class="technical-accordion">
          <details open class="accordion-item">
            <summary>
              <span>Detalhes técnicos</span>
              <span class="accordion-symbol" aria-hidden="true">
                <span class="symbol-plus">+</span>
                <span class="symbol-minus">−</span>
              </span>
            </summary>
            <div class="accordion-body">
              {detailsEntries.length > 0 ? (
                <dl class="technical-list">
                  {detailsEntries.map(([key, value]) => (
                    <div>
                      <dt>{key}</dt>
                      <dd>{value}</dd>
                    </div>
                  ))}
                </dl>
              ) : (
                <p>Detalhes técnicos incompletos no catálogo atual.</p>
              )}
            </div>
          </details>

          <details class="accordion-item">
            <summary>
              <span>Guia de tamanho</span>
              <span class="accordion-symbol" aria-hidden="true">
                <span class="symbol-plus">+</span>
                <span class="symbol-minus">−</span>
              </span>
            </summary>
            <div class="accordion-body">
              {sizeGuideLines.length > 0 ? (
                <div class="accordion-copy">
                  {sizeGuideLines.map((line) => <p>{line}</p>)}
                </div>
              ) : (
                <p>Guia de tamanho incompleto no catálogo atual.</p>
              )}
            </div>
          </details>

          <details class="accordion-item">
            <summary>
              <span>Política de troca</span>
              <span class="accordion-symbol" aria-hidden="true">
                <span class="symbol-plus">+</span>
                <span class="symbol-minus">−</span>
              </span>
            </summary>
            <div class="accordion-body">
              <p>Você tem 30 dias para trocar. O atendimento acontece pelo WhatsApp, sem burocracia.</p>
            </div>
          </details>
        </div>
      </aside>
    </section>

    <section class="reviews-section" aria-labelledby="product-reviews">
      <div class="reviews-inner">
        <header class="reviews-header">
          <h2 id="product-reviews" class="display-sm">Avaliações</h2>
          <p>4.8 ★</p>
        </header>
        <div class="reviews-grid">
          {reviews.map((review) => (
            <article class="review-card">
              <div class="review-stars" aria-label="5 estrelas">
                {Array.from({ length: 5 }).map(() => (
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path fill="currentColor" d="m12 2 2.9 6.1 6.7.9-4.8 4.7 1.1 6.6-5.9-3.1-5.9 3.1 1.1-6.6L2.4 9l6.7-.9L12 2z" />
                  </svg>
                ))}
              </div>
              <p class="review-quote">“{review.quote}”</p>
              <p class="review-name">{review.name}</p>
              <p class="review-city">{review.city}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    {relatedProducts.length > 0 && (
      <section class="related-section" aria-labelledby="related-products">
        <h2 id="related-products" class="display-sm related-title">Você também pode gostar</h2>
        <div class="related-track">
          {relatedProducts.map((related, index) => (
            <a href={`/produtos/${related.slug}`} class="related-card" aria-label={`Ver ${related.name}`}>
              <figure class="related-frame">
                <img
                  src={related.image}
                  srcset={relatedImageSrcset(related)}
                  sizes="(min-width: 768px) 25vw, 64vw"
                  alt={related.name}
                  class="related-image"
                  loading={index < 2 ? "eager" : "lazy"}
                  decoding="async"
                  width="900"
                  height="1200"
                />
              </figure>
              <h3>{related.name}</h3>
              <p>{formattedRelatedPrice(related.price)}</p>
            </a>
          ))}
        </div>
      </section>
    )}
  </article>

  {firstImage && (
    <div class="desktop-sticky-bar" data-sticky-bar aria-hidden="true">
      <div class="sticky-product">
        <img
          src={`/${firstImage.src}`}
          srcset={buildSrcset(firstImage)}
          sizes="40px"
          alt=""
          class="sticky-product-image"
          loading="lazy"
          decoding="async"
          width="80"
          height="106"
        />
        <div>
          <p class="sticky-product-name">{product.name}</p>
          <p class="sticky-product-price">{formattedPrice}</p>
        </div>
      </div>
      <a class="sticky-whatsapp-link" href={whatsappUrl}>
        <span>Consultar pelo WhatsApp</span>
      </a>
    </div>
  )}

  <style>
    .pdp-page {
      background: var(--rivano-off-white);
      color: var(--rivano-brown);
      overflow-x: hidden;
    }

    .pdp-main {
      display: flex;
      flex-direction: column;
      width: 100%;
    }

    .pdp-gallery {
      width: 100%;
    }

    .mobile-gallery {
      display: flex;
      gap: 0;
      margin-left: calc(50% - 50vw);
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      width: 100vw;
    }

    .mobile-gallery::-webkit-scrollbar {
      display: none;
    }

    .mobile-slide {
      flex: 0 0 100vw;
      scroll-snap-align: start;
    }

    .mobile-gallery-image,
    .desktop-main-image,
    .related-image {
      aspect-ratio: 3 / 4;
      display: block;
      height: auto;
      object-fit: cover;
      width: 100%;
    }

    .gallery-dots {
      align-items: center;
      display: flex;
      gap: 12px;
      justify-content: center;
      padding: 12px 24px 0;
    }

    .gallery-dot-button {
      align-items: center;
      background: transparent;
      border: 0;
      cursor: pointer;
      display: inline-flex;
      justify-content: center;
      min-height: 44px;
      min-width: 44px;
      padding: 8px;
    }

    .gallery-dot {
      background: var(--rivano-beige);
      border: 1px solid var(--rivano-muted);
      border-radius: 50%;
      display: block;
      height: 16px;
      width: 16px;
    }

    .gallery-dot.is-active {
      background: var(--rivano-brown);
      border: 0;
    }

    .desktop-gallery {
      display: none;
    }

    .gallery-empty {
      align-items: center;
      aspect-ratio: 3 / 4;
      background: var(--rivano-beige);
      color: var(--rivano-muted);
      display: flex;
      font-family: var(--font-sans);
      font-size: 11px;
      justify-content: center;
      letter-spacing: 0.14em;
      min-height: 420px;
      text-transform: uppercase;
      width: 100%;
    }

    .product-panel {
      display: flex;
      flex-direction: column;
      gap: 20px;
      padding: 28px 24px 48px;
    }

    .product-breadcrumb {
      align-items: center;
      color: color-mix(in srgb, var(--rivano-brown) 45%, transparent);
      display: flex;
      flex-wrap: wrap;
      font-family: var(--font-sans);
      font-size: 11px;
      gap: 8px;
      line-height: 1.3;
    }

    .product-breadcrumb a {
      align-items: center;
      display: inline-flex;
      min-height: 44px;
      text-decoration: none;
      transition: opacity var(--transition-normal);
    }

    .product-breadcrumb a:hover {
      opacity: 0.8;
    }

    .product-heading {
      display: flex;
      flex-direction: column;
      gap: 14px;
      margin-top: -4px;
    }

    .product-title {
      font-family: var(--font-serif);
      font-weight: 400;
    }

    .product-price-main {
      color: var(--rivano-brown);
      font-family: var(--font-sans);
      font-size: 22px;
      font-weight: 400;
      line-height: 1.2;
    }

    .trust-inline {
      align-items: center;
      color: color-mix(in srgb, var(--rivano-brown) 70%, transparent);
      display: flex;
      flex-wrap: wrap;
      font-family: var(--font-sans);
      font-size: 11px;
      font-weight: 400;
      gap: 12px;
      letter-spacing: 0;
      line-height: 1.4;
      margin-top: -8px;
    }

    .trust-separator {
      color: var(--rivano-muted);
    }

    .panel-label {
      color: var(--rivano-brown);
      font-family: var(--font-sans);
      font-size: 10px;
      font-weight: 400;
      letter-spacing: 0.1em;
      line-height: 1.4;
      margin-bottom: 8px;
      text-transform: uppercase;
    }

    .color-options {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }

    .color-choice {
      align-items: center;
      display: inline-flex;
      gap: 6px;
    }

    .color-option {
      align-items: center;
      background: transparent;
      border: 0;
      cursor: pointer;
      display: flex;
      justify-content: center;
      min-height: 44px;
      min-width: 44px;
      padding: 0;
      transition: var(--transition-fast);
    }

    .color-option.is-disabled {
      cursor: default;
      opacity: 0.45;
    }

    .color-dot {
      border: 1px solid var(--rivano-muted);
      border-radius: 50%;
      display: block;
      height: 24px;
      width: 24px;
    }

    .color-option.is-active .color-dot {
      outline: 2px solid var(--rivano-brown);
      outline-offset: 2px;
    }

    .color-name {
      color: color-mix(in srgb, var(--rivano-brown) 65%, transparent);
      font-family: var(--font-sans);
      font-size: 11px;
      line-height: 1.3;
    }

    .whatsapp-cta {
      align-items: center;
      background: var(--rivano-brown);
      color: var(--rivano-off-white);
      display: inline-flex;
      font-family: var(--font-sans);
      font-size: 12px;
      font-weight: 400;
      justify-content: center;
      letter-spacing: 0.12em;
      line-height: 1.2;
      margin-top: 4px;
      min-height: 52px;
      padding: 16px 24px;
      text-align: center;
      text-transform: uppercase;
      transition: opacity var(--transition-normal);
      width: 100%;
    }

    .whatsapp-cta:hover {
      opacity: 0.85;
    }

    .feature-icons {
      color: var(--rivano-brown);
      display: grid;
      gap: 16px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      margin-top: 8px;
    }

    .feature-icon {
      align-items: center;
      display: flex;
      flex-direction: column;
      gap: 9px;
      min-height: 74px;
      text-align: center;
    }

    .feature-icon svg {
      fill: none;
      height: 22px;
      stroke: currentColor;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-width: 1.4;
      width: 22px;
    }

    .feature-icon span {
      color: var(--rivano-brown);
      font-family: var(--font-sans);
      font-size: 10px;
      font-weight: 400;
      letter-spacing: 0.08em;
      line-height: 1.35;
      text-transform: uppercase;
    }

    .technical-accordion {
      margin-top: 4px;
    }

    .accordion-item {
      border-top: 1px solid var(--rivano-beige);
    }

    .accordion-item:last-child {
      border-bottom: 1px solid var(--rivano-beige);
    }

    .accordion-item summary {
      align-items: center;
      cursor: pointer;
      display: flex;
      font-family: var(--font-sans);
      font-size: 12px;
      font-weight: 400;
      justify-content: space-between;
      letter-spacing: 0.08em;
      line-height: 1.35;
      list-style: none;
      min-height: 44px;
      text-transform: uppercase;
    }

    .accordion-item summary::-webkit-details-marker {
      display: none;
    }

    .accordion-symbol {
      align-items: center;
      display: inline-flex;
      justify-content: center;
      min-height: 44px;
      min-width: 44px;
    }

    .symbol-minus {
      display: none;
    }

    .accordion-item[open] .symbol-plus {
      display: none;
    }

    .accordion-item[open] .symbol-minus {
      display: inline;
    }

    .accordion-body {
      color: color-mix(in srgb, var(--rivano-brown) 70%, transparent);
      font-family: var(--font-sans);
      font-size: 13px;
      line-height: 1.7;
      max-height: 0;
      overflow: hidden;
