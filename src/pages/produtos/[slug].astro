  <script is:inline>
    const carousel = document.querySelector("[data-carousel]");
    const dots = Array.from(document.querySelectorAll("[data-dot]"));

    if (carousel && dots.length > 0) {
      const setActiveDot = (index) => {
        dots.forEach((dot, dotIndex) => {
          const indicator = dot.querySelector("[data-dot-indicator]");
          const isActive = dotIndex === index;
          dot.setAttribute("aria-current", isActive ? "true" : "false");
          indicator?.classList.toggle("is-active", isActive);
        });
      };

      const getCarouselIndex = () => {
        const width = carousel.clientWidth || 1;
        return Math.round(carousel.scrollLeft / width);
      };

      setActiveDot(0);

      carousel.addEventListener("scroll", () => {
        setActiveDot(getCarouselIndex());
      });

      dots.forEach((dot) => {
        dot.addEventListener("click", () => {
          const index = Number(dot.getAttribute("data-dot") || 0);
          const width = carousel.clientWidth || 1;
          carousel.scrollTo({ left: width * index, behavior: "smooth" });
        });
      });
    }

    const mainImage = document.querySelector("[data-main-image]");
    const thumbnails = Array.from(document.querySelectorAll("[data-thumb]"));

    if (mainImage && thumbnails.length > 0) {
      thumbnails.forEach((thumbnail) => {
        thumbnail.addEventListener("click", () => {
          const nextSrc = thumbnail.getAttribute("data-thumb-src");
          const nextSrcset = thumbnail.getAttribute("data-thumb-srcset") || "";
          const nextAlt = thumbnail.getAttribute("data-thumb-alt") || "";

          if (!nextSrc || mainImage.getAttribute("src") === nextSrc) {
            return;
          }

          thumbnails.forEach((item) => {
            const isActive = item === thumbnail;
            item.classList.toggle("is-active", isActive);
            item.setAttribute("aria-current", isActive ? "true" : "false");
          });

          mainImage.style.opacity = "0";

          window.setTimeout(() => {
            mainImage.setAttribute("src", nextSrc);
            mainImage.setAttribute("srcset", nextSrcset);
            mainImage.setAttribute("alt", nextAlt);

            const reveal = () => {
              mainImage.style.opacity = "1";
              mainImage.removeEventListener("load", reveal);
            };

            mainImage.addEventListener("load", reveal);

            if (mainImage.complete) {
              reveal();
            }
          }, 120);
        });
      });
    }

    const variantOptions = Array.from(document.querySelectorAll("[data-variant-option]"));
    const whatsappLinks = Array.from(document.querySelectorAll("[data-whatsapp-link]"));
    const whatsappPrefix = "https://wa.me/5571993135522?text=";

    const updateWhatsappLinks = (message) => {
      if (!message) {
        return;
      }

      whatsappLinks.forEach((link) => {
        link.setAttribute("href", whatsappPrefix + encodeURIComponent(message));
      });
    };

    const activeVariant = variantOptions.find((option) => option.classList.contains("is-active"));
    updateWhatsappLinks(activeVariant?.getAttribute("data-whatsapp-message"));

    variantOptions.forEach((option) => {
      option.addEventListener("click", () => {
        if (option instanceof HTMLButtonElement && option.disabled) {
          return;
        }

        variantOptions.forEach((item) => {
          const isActive = item === option;
          item.classList.toggle("is-active", isActive);
          item.setAttribute("aria-pressed", isActive ? "true" : "false");
        });

        updateWhatsappLinks(option.getAttribute("data-whatsapp-message"));
      });
    });

    const primaryCta = document.querySelector("[data-primary-cta]");
    const stickyTargets = Array.from(document.querySelectorAll("[data-sticky-bar], [data-mobile-sticky-cta]"));

    if (primaryCta && stickyTargets.length > 0 && "IntersectionObserver" in window) {
      const setStickyVisibility = (show) => {
        stickyTargets.forEach((target) => {
          target.toggleAttribute("hidden", !show);
        });
      };

      setStickyVisibility(false);

      const observer = new IntersectionObserver(
        ([entry]) => {
          setStickyVisibility(!entry.isIntersecting);
        },
        { threshold: 0 },
      );

      observer.observe(primaryCta);
    }
  </script>
