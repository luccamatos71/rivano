---
import CTAButton from "../../components/CTAButton.astro";
import ProductCard from "../../components/ProductCard.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  buildSrcset,
  getImageSets,
  getProductDescription,
  pickRelatedProducts,
  toCardProduct,
  toParagraphs,
  type Product,
} from "../../lib/products";
import productsData from "../../data/products.json";

const allProducts = productsData as Product[];

export function getStaticPaths() {
  const products = productsData as Product[];
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

const { product } = Astro.props as { product: Product };
const imageSets = getImageSets(product.images);
const relatedProducts = pickRelatedProducts(allProducts, product.slug, 4);
const relatedCardProducts = relatedProducts.map(toCardProduct);
const productDescription = getProductDescription(product);
const detailsEntries = Object.entries(product.description.details ?? {});
const hasDescription =
  detailsEntries.length > 0 ||
  Boolean(product.description.fit) ||
  Boolean(product.description.experience) ||
  Boolean(product.description.body) ||
  Boolean(product.description.testimonial);

const selectedVariantIndex =
  product.variants.findIndex((variant) => variant.stock > 0) >= 0
    ? product.variants.findIndex((variant) => variant.stock > 0)
    : 0;

function sectionLines(value: string | null): string[] {
  if (!value) {
    return [];
  }

  return toParagraphs(value).filter((line) => {
    const normalized = line.toLowerCase();
    return normalized !== "rivano experience" && normalized !== "como fica" && normalized !== "detalhes";
  });
}
---

<BaseLayout title={`${product.name} | Rivano`} description={productDescription}>
  <section class="page-wrap section-space pb-28 md:pb-[100px]">
    <div class="mb-5 border-b border-[var(--rivano-areia)] pb-4 text-[11px] uppercase tracking-[0.18em] text-[var(--rivano-muted)]">
      <a href="/catalogo" class="transition-colors duration-200 hover:text-[var(--rivano-brown)]">Modelos</a>
      <span class="px-2">/</span>
      <span>{product.name}</span>
    </div>

    <div class="grid gap-8 md:grid-cols-[1.65fr_1fr] md:gap-10">
      <div>
        <div class="flex snap-x snap-mandatory gap-2 overflow-x-auto md:hidden" data-carousel>
          {
            imageSets.map((imageSet, index) => (
              <figure class="min-w-full snap-start" data-slide={index}>
                <img
                  src={`/${imageSet.src}`}
                  srcset={buildSrcset(imageSet)}
                  sizes="100vw"
                  alt={`${product.name} - foto ${index + 1}`}
                  class="aspect-[3/4] h-auto w-full bg-[var(--rivano-off-white)] object-contain p-6"
                  loading={index === 0 ? "eager" : "lazy"}
                  decoding="async"
                  width="900"
                  height="1200"
                />
              </figure>
            ))
          }
        </div>

        {imageSets.length > 1 && (
          <div class="mt-3 flex justify-center gap-2 md:hidden" data-dots>
            {imageSets.map((_, index) => <button type="button" data-dot={index} class="h-2 w-2 rounded-full bg-[var(--rivano-areia)]"></button>)}
          </div>
        )}

        <div class="hidden space-y-4 md:block">
          {
            imageSets.map((imageSet, index) => (
              <figure>
                <img
                  src={`/${imageSet.src}`}
                  srcset={buildSrcset(imageSet)}
                  sizes="(min-width: 768px) 62vw, 100vw"
                  alt={`${product.name} - foto ${index + 1}`}
                  class="aspect-[3/4] h-auto w-full bg-[var(--rivano-off-white)] object-contain p-6"
                  loading={index === 0 ? "eager" : "lazy"}
                  decoding="async"
                  width="900"
                  height="1200"
                />
              </figure>
            ))
          }
        </div>
      </div>

      <aside class="md:sticky md:top-24 md:self-start">
        <h1 class="font-['Cormorant_Garamond'] text-[44px] leading-[0.95] tracking-[0.05em] md:text-[54px]">{product.name}</h1>
        <p class="mt-4 text-[24px] font-light text-[var(--rivano-brown)]">
          {new Intl.NumberFormat("pt-BR", { style: "currency", currency: "BRL", maximumFractionDigits: 0 }).format(product.price)}
        </p>

        <div class="mt-4 flex flex-wrap items-center gap-4 font-['DM_Sans'] text-[12px] font-normal leading-none text-[var(--rivano-muted)]">
          <span class="inline-flex items-center gap-1.5">
            <svg class="h-[14px] w-[14px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M7 7h9.5a4.5 4.5 0 0 1 0 9H8" />
              <path d="M10 4 7 7l3 3" />
              <path d="M14 20l3-3-3-3" />
            </svg>
            Troca em 30 dias
          </span>
          <span class="inline-flex items-center gap-1.5">
            <svg class="h-[14px] w-[14px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M3 7h11v9H3z" />
              <path d="M14 10h3.5l2.5 3v3h-6z" />
              <path d="M6.5 19a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3z" />
              <path d="M17.5 19a1.5 1.5 0 1 0 0-3 1.5 1.5 0 0 0 0 3z" />
            </svg>
            Frete grátis
          </span>
          <span class="inline-flex items-center gap-1.5">
            <svg class="h-[14px] w-[14px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="m5 12 4 4L19 6" />
            </svg>
            100% original
          </span>
        </div>

        {product.description.testimonial && (
          <blockquote class="mt-5 font-['DM_Sans'] text-[14px] italic leading-[1.8] text-[var(--rivano-dark)]">
            <p>&ldquo;{product.description.testimonial.text}&rdquo;</p>
            {product.description.testimonial.author && (
              <footer class="mt-2 text-[var(--rivano-muted)]">— {product.description.testimonial.author}</footer>
            )}
          </blockquote>
        )}

        {product.variants.length > 0 && (
          <div class="mt-8">
            <p class="editorial-label mb-3">Variações</p>
            <div class="flex flex-wrap gap-3">
              {product.variants.map((variant, index) => (
                <div class="inline-flex items-center gap-2">
                  <span
                    class:list={[
                      "inline-flex h-5 w-5 items-center justify-center rounded-full border border-[var(--rivano-areia)] text-[9px] uppercase tracking-[0.08em]",
                      index === selectedVariantIndex && "border-[var(--rivano-dark)]",
                      variant.stock <= 0 && "opacity-50",
                    ]}
                  >
                    {variant.name.slice(0, 1)}
                  </span>
                  <span class:list={["text-[13px] text-[var(--rivano-dark)]", variant.stock <= 0 && "text-[var(--rivano-muted)]"]}>
                    {variant.name}
                  </span>
                </div>
              ))}
            </div>
          </div>
        )}

        <div class="mt-8 hidden md:block">
          <CTAButton fullWidth text={product.name} />
        </div>

        <div class="mt-9 border-t border-[var(--rivano-areia)]">
          {detailsEntries.length > 0 && (
            <details open class="border-b border-[var(--rivano-areia)] py-3">
              <summary class="cursor-pointer text-[12px] uppercase tracking-[0.16em] text-[var(--rivano-dark)]">Detalhes</summary>
              <dl class="mt-3 space-y-2 text-[14px] leading-[1.7] text-[var(--rivano-dark)]">
                {detailsEntries.map(([key, value]) => (
                  <div class="grid grid-cols-[110px_1fr] gap-2">
                    <dt class="text-[var(--rivano-muted)]">{key}</dt>
                    <dd>{value}</dd>
                  </div>
                ))}
              </dl>
            </details>
          )}

          {sectionLines(product.description.fit).length > 0 && (
            <details class="border-b border-[var(--rivano-areia)] py-3">
              <summary class="cursor-pointer text-[12px] uppercase tracking-[0.16em] text-[var(--rivano-dark)]">Como fica</summary>
              <div class="mt-3 space-y-2 text-[14px] leading-[1.8] text-[var(--rivano-dark)]">
                {sectionLines(product.description.fit).map((line) => <p>{line}</p>)}
              </div>
            </details>
          )}

          {sectionLines(product.description.experience).length > 0 && (
            <details class="border-b border-[var(--rivano-areia)] py-3">
              <summary class="cursor-pointer text-[12px] uppercase tracking-[0.16em] text-[var(--rivano-dark)]">Experiência</summary>
              <div class="mt-3 space-y-2 text-[14px] leading-[1.8] text-[var(--rivano-dark)]">
                {sectionLines(product.description.experience).map((line) => <p>{line}</p>)}
              </div>
            </details>
          )}

          {sectionLines(product.description.body).length > 0 && (
            <details class="border-b border-[var(--rivano-areia)] py-3">
              <summary class="cursor-pointer text-[12px] uppercase tracking-[0.16em] text-[var(--rivano-dark)]">Descrição</summary>
              <div class="mt-3 space-y-2 text-[14px] leading-[1.8] text-[var(--rivano-dark)]">
                {sectionLines(product.description.body).map((line) => <p>{line}</p>)}
              </div>
            </details>
          )}

          {!hasDescription && <p class="py-3 text-[13px] text-[var(--rivano-muted)]">Descrição incompleta no catálogo atual.</p>}
        </div>
      </aside>
    </div>

    {relatedProducts.length > 0 && (
      <section class="mt-14 border-t border-[var(--rivano-areia)] pt-10 md:mt-20 md:pt-12">
        <header class="mb-8">
          <p class="editorial-label mb-3">Você também pode gostar</p>
          <h2 class="font-['Cormorant_Garamond'] text-[38px] leading-[1] tracking-[0.05em] md:text-[50px]">Mais modelos</h2>
        </header>
        <div class="grid grid-cols-2 gap-3 md:grid-cols-4 md:gap-6">
          {
            relatedCardProducts.map((item) => (
              <ProductCard
                slug={item.slug}
                name={item.name}
                price={item.price}
                stock={item.stock}
                image={item.image}
                hoverImage={item.hoverImage}
                available={item.available}
              />
            ))
          }
        </div>
      </section>
    )}
  </section>

  <div class="fixed inset-x-0 bottom-14 z-40 border-t border-[var(--rivano-areia)] bg-[#f5f1e8]/95 p-4 backdrop-blur md:hidden">
    <CTAButton fullWidth text={product.name} />
  </div>

  <script is:inline>
    const carousel = document.querySelector("[data-carousel]");
    const dots = Array.from(document.querySelectorAll("[data-dot]"));

    if (carousel && dots.length > 0) {
      const setActive = (index) => {
        dots.forEach((dot, dotIndex) => {
          dot.classList.toggle("bg-[var(--rivano-dark)]", dotIndex === index);
          dot.classList.toggle("bg-[var(--rivano-areia)]", dotIndex !== index);
        });
      };

      const getIndex = () => {
        const width = carousel.clientWidth || 1;
        return Math.round(carousel.scrollLeft / width);
      };

      setActive(0);

      carousel.addEventListener("scroll", () => {
        setActive(getIndex());
      });

      dots.forEach((dot) => {
        dot.addEventListener("click", () => {
          const index = Number(dot.getAttribute("data-dot") || 0);
          const width = carousel.clientWidth || 1;
          carousel.scrollTo({ left: width * index, behavior: "smooth" });
        });
      });
    }
  </script>
</BaseLayout>
