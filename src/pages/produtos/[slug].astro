---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  buildSrcset,
  getImageSets,
  getProductDescription,
  pickRelatedProducts,
  toCardProduct,
  toParagraphs,
  type CardProduct,
  type Product,
} from "../../lib/products";
import productsData from "../../data/products.json";

const allProducts = productsData as Product[];

export function getStaticPaths() {
  const products = productsData as Product[];
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { product },
  }));
}

type VariantWithColor = Product["variants"][number] & {
  color?: string;
  hex?: string;
  value?: string;
};

type DisplayVariant = Product["variants"][number] & {
  colorValue: string | null;
  message: string;
};

const { product } = Astro.props as { product: Product };
const imageSets = getImageSets(product.images);
const firstImage = imageSets[0];
const relatedProducts = pickRelatedProducts(allProducts, product.slug, 4).map(toCardProduct);
const productDescription = getProductDescription(product);
const currentStock = product.stock ?? 0;
const isPurchasable = product.available === true && currentStock > 0;
const isLowStock = isPurchasable && currentStock <= 3;
const ctaLabel = isPurchasable ? "Comprar pelo WhatsApp" : "Consultar reposi\u00e7\u00e3o";
const availabilityText = !isPurchasable
  ? "Indispon\u00edvel no momento"
  : isLowStock
    ? "Poucas unidades dispon\u00edveis"
    : "Dispon\u00edvel para compra assistida";
const formattedPrice = new Intl.NumberFormat("pt-BR", {
  style: "currency",
  currency: "BRL",
  minimumFractionDigits: 2,
  maximumFractionDigits: 2,
}).format(product.price);
const availableWhatsappMessage = `Ol\u00e1! Tenho interesse no ${product.name}. Podem me ajudar com disponibilidade e frete?`;
const unavailableWhatsappMessage = `Ol\u00e1! Tenho interesse no ${product.name}. Podem me avisar quando voltar ou indicar modelos parecidos?`;
const whatsappMessage = isPurchasable ? availableWhatsappMessage : unavailableWhatsappMessage;
const whatsappUrl = `https://wa.me/5571993135522?text=${encodeURIComponent(whatsappMessage)}`;
const detailsEntries = Object.entries(product.description.details ?? {});
const sizeGuideLines = sectionLines(product.description.fit);
const selectedVariantIndex =
  product.variants.findIndex((variant) => variant.stock > 0) >= 0
    ? product.variants.findIndex((variant) => variant.stock > 0)
    : 0;
const displayVariants: DisplayVariant[] = product.variants.map((variant) => ({
  ...variant,
  colorValue: getVariantColor(variant as VariantWithColor),
  message: buildVariantWhatsappMessage(product.name, variant.name, isPurchasable),
}));
const hasIncludedCopy = hasCaseAndFlanela(product);
const includedCopy = hasIncludedCopy ? "Acompanha case e flanela." : "Informa\u00e7\u00e3o incompleta no cat\u00e1logo atual.";
const incompleteCopy = "Informa\u00e7\u00e3o incompleta no cat\u00e1logo atual.";
const productUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).toString();
const productJsonLd = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: product.name,
  description: productDescription,
  image: imageSets.map((imageSet) => new URL(`/${imageSet.src}`, Astro.site ?? Astro.url.origin).toString()),
  offers: {
    "@type": "Offer",
    price: product.price,
    priceCurrency: "BRL",
    availability: isPurchasable ? "https://schema.org/InStock" : "https://schema.org/OutOfStock",
    url: productUrl,
  },
};

function sectionLines(value: string | null): string[] {
  if (!value) {
    return [];
  }

  return toParagraphs(value).filter((line) => {
    const normalized = line.toLowerCase();
    return normalized !== "rivano experience" && normalized !== "como fica" && normalized !== "detalhes";
  });
}

function normalizeText(value: string): string {
  return value
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "")
    .toLowerCase();
}

function getVariantColor(variant: VariantWithColor): string | null {
  const explicitColor = variant.color ?? variant.hex ?? variant.value;

  if (explicitColor) {
    return explicitColor;
  }

  const name = normalizeText(variant.name);

  if (name.includes("clara") || name.includes("transparente")) {
    return "var(--rivano-beige)";
  }

  if (name.includes("escura") || name.includes("preta") || name.includes("grafite")) {
    return "var(--rivano-brown)";
  }

  if (name.includes("marrom") || name.includes("tartaruga")) {
    return "var(--rivano-brown-mid)";
  }

  if (name.includes("dourad")) {
    return "var(--rivano-gold)";
  }

  return null;
}

function buildVariantWhatsappMessage(productName: string, variantName: string, available: boolean): string {
  if (available) {
    return `Ol\u00e1! Tenho interesse no ${productName} - ${variantName}. Podem me ajudar com disponibilidade e frete?`;
  }

  return `Ol\u00e1! Tenho interesse no ${productName} - ${variantName}. Podem me avisar quando voltar ou indicar modelos parecidos?`;
}

function hasCaseAndFlanela(product: Product): boolean {
  const values = [
    product.description.body,
    product.description.experience,
    product.description.fit,
    ...Object.entries(product.description.details ?? {}).flat(),
  ]
    .filter(Boolean)
    .join(" ");
  const normalized = normalizeText(values);

  return normalized.includes("case") && normalized.includes("flanela");
}

function relatedImageSrcset(product: CardProduct): string {
  const normalized = product.image.startsWith("/") ? product.image : `/${product.image}`;

  if (!/-(?:600|1200|2000)\.webp$/i.test(normalized)) {
    return "";
  }

  return [600, 1200, 2000]
    .map((width) => `${normalized.replace(/-(?:600|1200|2000)\.webp$/i, `-${width}.webp`)} ${width}w`)
    .join(", ");
}

function formattedRelatedPrice(value: number): string {
  return new Intl.NumberFormat("pt-BR", {
    style: "currency",
    currency: "BRL",
    minimumFractionDigits: 2,
    maximumFractionDigits: 2,
  }).format(value);
}
---

<BaseLayout title={`${product.name} | Rivano`} description={productDescription} showBottomBar={false}>
  <script type="application/ld+json" set:html={JSON.stringify(productJsonLd)} />
  <article class="pdp-page">
    <section class="pdp-main" aria-label={`Detalhes de ${product.name}`}>
      <div class="pdp-gallery">
        {imageSets.length > 0 ? (
          <>
            <div class="mobile-gallery" data-carousel aria-label={`Galeria de imagens de ${product.name}`}>
              {imageSets.map((imageSet, index) => (
                <figure class="mobile-slide" data-slide={index}>
                  <img
                    src={`/${imageSet.src}`}
                    srcset={buildSrcset(imageSet)}
                    sizes="100vw"
                    alt={`${product.name} - foto ${index + 1}`}
                    class="mobile-gallery-image"
                    loading={index === 0 ? "eager" : "lazy"}
                    fetchpriority={index === 0 ? "high" : undefined}
                    decoding="async"
                    width="900"
                    height="1200"
                  />
                  {index === 0 && (
                    <div class="gallery-overlay" aria-hidden="true">
                      <div class="gallery-gradient"></div>
                      <div class="gallery-product-info">
                        <span class="gallery-product-name">{product.name}</span>
                        <span class="gallery-product-price">{formattedPrice}</span>
                      </div>
                    </div>
                  )}
                </figure>
              ))}
            </div>

            {imageSets.length > 1 && (
              <div class="gallery-dots" data-dots>
                {imageSets.map((_, index) => (
                  <button
                    type="button"
                    class="gallery-dot-button"
                    data-dot={index}
                    aria-label={`Mostrar foto ${index + 1}`}
                    aria-current={index === 0 ? "true" : "false"}
                  >
                    <span class:list={["gallery-dot", index === 0 && "is-active"]} data-dot-indicator></span>
                  </button>
                ))}
              </div>
            )}

            <div class="desktop-gallery" aria-label={`Galeria de imagens de ${product.name}`}>
              <figure class="desktop-main-frame">
                <img
                  src={`/${firstImage.src}`}
                  srcset={buildSrcset(firstImage)}
                  sizes="(min-width: 768px) 58vw, 100vw"
                  alt={`${product.name} - foto 1`}
                  class="desktop-main-image"
                  data-main-image
                  loading="eager"
                  fetchpriority="high"
                  decoding="async"
                  width="900"
                  height="1200"
                />
              </figure>

              {imageSets.length > 1 && (
                <div class="thumbnail-row" aria-label="Escolha uma foto">
                  {imageSets.map((imageSet, index) => (
                    <button
                      type="button"
                      class:list={["thumbnail-button", index === 0 && "is-active"]}
                      data-thumb={index}
                      data-thumb-src={`/${imageSet.src}`}
                      data-thumb-srcset={buildSrcset(imageSet)}
                      data-thumb-alt={`${product.name} - foto ${index + 1}`}
                      aria-label={`Ver foto ${index + 1}`}
                      aria-current={index === 0 ? "true" : "false"}
                    >
                      <img
                        src={`/${imageSet.src}`}
                        srcset={buildSrcset(imageSet)}
                        sizes="72px"
                        alt=""
                        class="thumbnail-image"
                        loading={index < 6 ? "eager" : "lazy"}
                        decoding="async"
                        width="144"
                        height="192"
                      />
                    </button>
                  ))}
                </div>
              )}
            </div>
          </>
        ) : (
          <div class="gallery-empty">Imagem indisponível</div>
        )}
      </div>

      <aside class="product-panel">
        <nav class="product-breadcrumb" aria-label="Caminho do produto">
          <a href="/">In&iacute;cio</a>
          <span aria-hidden="true">/</span>
          <a href="/catalogo">Cat&aacute;logo</a>
          <span aria-hidden="true">/</span>
          <span>{product.name}</span>
        </nav>

        <div class="product-heading">
          <h1 class="display-md product-title">{product.name}</h1>
          <p class="product-price-main">{formattedPrice}</p>
        </div>

        <p class="product-microcopy">Design leve, prote&ccedil;&atilde;o UV400 e presen&ccedil;a para os dias de sol.</p>
        <p class:list={["product-availability", !isPurchasable && "is-unavailable"]}>{availabilityText}</p>

        {displayVariants.length > 0 && (
          <div class="variant-selector" aria-label="Sele&ccedil;&atilde;o de varia&ccedil;&atilde;o">
            <p class="panel-label">Varia&ccedil;&atilde;o</p>
            <div class="variant-options">
              {displayVariants.map((variant, index) => (
                <button
                  type="button"
                  class:list={[
                    "variant-option",
                    index === selectedVariantIndex && variant.stock > 0 && "is-active",
                    variant.stock <= 0 && "is-disabled",
                  ]}
                  aria-label={`Selecionar ${variant.name}`}
                  aria-pressed={index === selectedVariantIndex && variant.stock > 0 ? "true" : "false"}
                  data-variant-option
                  data-whatsapp-message={variant.message}
                  disabled={variant.stock <= 0}
                >
                  {variant.colorValue && <span class="variant-swatch" style={`background: ${variant.colorValue};`}></span>}
                  <span>{variant.name}</span>
                </button>
              ))}
            </div>
          </div>
        )}

        <a class:list={["whatsapp-cta", !isPurchasable && "is-secondary"]} href={whatsappUrl} data-primary-cta data-whatsapp-link>
          {ctaLabel}
        </a>

        <p class="purchase-support">Atendimento humano para confirmar disponibilidade e frete.</p>

        <div class="trust-strip" aria-label="Confian&ccedil;a Rivano">
          <span><strong>01</strong> Prote&ccedil;&atilde;o UV400</span>
          <span><strong>02</strong> Case e flanela</span>
          <span><strong>03</strong> Troca em at&eacute; 30 dias</span>
          <span><strong>04</strong> Garantia contra defeitos</span>
        </div>

        <div class="technical-accordion">
          <details open={detailsEntries.length > 0} class="accordion-item">
            <summary>
              <span>Detalhes do modelo</span>
              <span class="accordion-symbol" aria-hidden="true">
                <span class="symbol-plus">+</span>
                <span class="symbol-minus">&minus;</span>
              </span>
            </summary>
            <div class="accordion-body">
              {detailsEntries.length > 0 ? (
                <dl class="technical-list">
                  {detailsEntries.map(([key, value]) => (
                    <div>
                      <dt>{key}</dt>
                      <dd>{value}</dd>
                    </div>
                  ))}
                </dl>
              ) : (
                <p>{incompleteCopy}</p>
              )}
            </div>
          </details>

          <details class="accordion-item">
            <summary>
              <span>Como fica no rosto</span>
              <span class="accordion-symbol" aria-hidden="true">
                <span class="symbol-plus">+</span>
                <span class="symbol-minus">&minus;</span>
              </span>
            </summary>
            <div class="accordion-body">
              {sizeGuideLines.length > 0 ? (
                <div class="accordion-copy">
                  {sizeGuideLines.map((line) => <p>{line}</p>)}
                </div>
              ) : (
                <p>{incompleteCopy}</p>
              )}
            </div>
          </details>

          <details class="accordion-item">
            <summary>
              <span>O que acompanha</span>
              <span class="accordion-symbol" aria-hidden="true">
                <span class="symbol-plus">+</span>
                <span class="symbol-minus">&minus;</span>
              </span>
            </summary>
            <div class="accordion-body">
              <p>{includedCopy}</p>
            </div>
          </details>

          <details class="accordion-item">
            <summary>
              <span>Trocas e garantia</span>
              <span class="accordion-symbol" aria-hidden="true">
                <span class="symbol-plus">+</span>
                <span class="symbol-minus">&minus;</span>
              </span>
            </summary>
            <div class="accordion-body">
              <p>Voc&ecirc; tem at&eacute; 30 dias para trocar. O atendimento acontece pelo WhatsApp.</p>
            </div>
          </details>
        </div>
      </aside>
    </section>

    <section class="assisted-section" aria-labelledby="assisted-purchase">
      <div class="assisted-inner">
        <header class="assisted-header">
          <p class="assisted-label">Compra assistida</p>
          <h2 id="assisted-purchase" class="display-sm assisted-title">Compra assistida Rivano</h2>
          <p>Voc&ecirc; escolhe o modelo, fala com a gente pelo WhatsApp e finaliza com atendimento humano.</p>
        </header>
        <div class="assisted-grid">
          <article class="assisted-card">
            <span>01</span>
            <h3>Atendimento humano</h3>
            <p>Tiramos d&uacute;vidas antes da compra.</p>
          </article>
          <article class="assisted-card">
            <span>02</span>
            <h3>Envio e disponibilidade</h3>
            <p>Confirmamos frete e estoque no atendimento.</p>
          </article>
          <article class="assisted-card">
            <span>03</span>
            <h3>Troca sem burocracia</h3>
            <p>Voc&ecirc; tem at&eacute; 30 dias para trocar.</p>
          </article>
        </div>
      </div>
    </section>

    {relatedProducts.length > 0 && (
      <section class="related-section" aria-labelledby="related-products">
        <h2 id="related-products" class="display-sm related-title">Na mesma curadoria</h2>
        <div class="related-track">
          {relatedProducts.map((related, index) => (
            <a href={`/produtos/${related.slug}`} class="related-card" aria-label={`Ver ${related.name}`}>
              <figure class="related-frame">
                <img
                  src={related.image}
                  srcset={relatedImageSrcset(related)}
                  sizes="(min-width: 768px) 25vw, 64vw"
                  alt={related.name}
                  class="related-image"
                  loading={index < 2 ? "eager" : "lazy"}
                  decoding="async"
                  width="900"
                  height="1200"
                />
              </figure>
              <h3>{related.name}</h3>
              <p>{formattedRelatedPrice(related.price)}</p>
            </a>
          ))}
        </div>
      </section>
    )}
  </article>

  <div class="mobile-sticky-cta" data-mobile-sticky-cta hidden>
    <div class="mobile-sticky-copy">
      <p>{product.name}</p>
      <span>{formattedPrice}</span>
    </div>
    <a class="mobile-sticky-link" href={whatsappUrl} data-whatsapp-link>{ctaLabel}</a>
  </div>

  {firstImage && (
    <div class="desktop-sticky-bar" data-sticky-bar hidden>
      <div class="sticky-product">
        <img
          src={`/${firstImage.src}`}
          srcset={buildSrcset(firstImage)}
          sizes="40px"
          alt=""
          class="sticky-product-image"
          loading="lazy"
          decoding="async"
          width="80"
          height="106"
        />
        <div>
          <p class="sticky-product-name">{product.name}</p>
          <p class="sticky-product-price">{formattedPrice}</p>
        </div>
      </div>
      <a class="sticky-whatsapp-link" href={whatsappUrl} data-whatsapp-link>
        <span>{ctaLabel}</span>
      </a>
    </div>
  )}

  <style>
    .pdp-page {
      background: var(--rivano-off-white);
      color: var(--rivano-brown);
      overflow-x: hidden;
    }

    .pdp-main {
      display: flex;
      flex-direction: column;
      width: 100%;
    }

    .pdp-gallery {
      width: 100%;
    }

    .mobile-gallery {
      display: flex;
      margin-left: calc(50% - 50vw);
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scrollbar-width: none;
      width: 100vw;
    }

    .mobile-gallery::-webkit-scrollbar,
    .related-track::-webkit-scrollbar {
      display: none;
    }

    .mobile-slide {
      align-items: flex-start;
      background: color-mix(in srgb, var(--rivano-off-white) 82%, var(--rivano-beige));
      display: flex;
      flex: 0 0 100vw;
      justify-content: center;
      margin: 0;
      min-height: 88svh;
      overflow: hidden;
      position: relative;
      scroll-snap-align: start;
    }

    .desktop-main-image,
    .related-image {
      aspect-ratio: 3 / 4;
      display: block;
      height: 100%;
      mix-blend-mode: multiply;
      object-fit: contain;
      padding: 30px;
      width: 100%;
    }

    .mobile-gallery-image {
      aspect-ratio: 3 / 4;
      display: block;
      height: auto;
      mix-blend-mode: multiply;
      object-fit: cover;
      width: 100%;
    }

    .gallery-overlay {
      inset: 0;
      pointer-events: none;
      position: absolute;
    }

    .gallery-gradient {
      background: linear-gradient(
        0deg,
        color-mix(in srgb, var(--rivano-off-white) 85%, transparent) 0%,
        color-mix(in srgb, var(--rivano-off-white) 18%, transparent) 60%,
        transparent 100%
      );
      bottom: 0;
      height: 52%;
      left: 0;
      position: absolute;
      right: 0;
    }

    .gallery-product-info {
      bottom: 0;
      display: flex;
      flex-direction: column;
      gap: 4px;
      left: 0;
      padding: 20px 24px 28px;
      position: absolute;
      right: 0;
    }

    .gallery-product-name {
      color: var(--rivano-brown);
      font-family: var(--font-serif);
      font-size: 38px;
      font-weight: 300;
      letter-spacing: 0;
      line-height: 0.95;
    }

    .gallery-product-price {
      color: color-mix(in srgb, var(--rivano-brown) 70%, transparent);
      font-family: var(--font-sans);
      font-size: 15px;
      font-weight: 300;
    }

    .gallery-dots {
      align-items: center;
      display: flex;
      gap: 6px;
      justify-content: center;
      padding: 12px 24px 0;
    }

    .gallery-dot-button {
      align-items: center;
      background: transparent;
      border: 0;
      cursor: pointer;
      display: inline-flex;
      justify-content: center;
      min-height: 44px;
      min-width: 44px;
      padding: 8px;
    }

    .gallery-dot {
      background: transparent;
      border: 1px solid color-mix(in srgb, var(--rivano-brown) 35%, transparent);
      border-radius: 50%;
      display: block;
      height: 16px;
      width: 16px;
    }

    .gallery-dot.is-active {
      background: var(--rivano-brown);
      border-color: var(--rivano-brown);
    }

    .desktop-gallery {
      display: none;
    }

    .gallery-empty {
      align-items: center;
      aspect-ratio: 3 / 4;
      background: color-mix(in srgb, var(--rivano-off-white) 82%, var(--rivano-beige));
      color: var(--rivano-muted);
      display: flex;
      font-family: var(--font-sans);
      font-size: 11px;
      justify-content: center;
      letter-spacing: 0.14em;
      min-height: 420px;
      text-transform: uppercase;
      width: 100%;
    }

    .product-panel {
      display: flex;
      flex-direction: column;
      gap: 18px;
      padding: 30px 24px 56px;
    }

    .product-breadcrumb {
      align-items: center;
      color: color-mix(in srgb, var(--rivano-brown) 42%, transparent);
      display: flex;
      flex-wrap: wrap;
      font-family: var(--font-sans);
      font-size: 10px;
      gap: 8px;
      letter-spacing: 0.08em;
      line-height: 1.3;
      text-transform: uppercase;
    }

    .product-breadcrumb a {
      align-items: center;
      display: inline-flex;
      min-height: 44px;
      text-decoration: none;
      transition: opacity var(--transition-normal);
    }

    .product-breadcrumb a:hover {
      opacity: 0.75;
    }

    .product-heading {
      display: none;
    }

    .product-title {
      color: var(--rivano-brown);
      font-family: var(--font-serif);
      font-size: 46px;
      font-weight: 300;
      letter-spacing: 0;
      line-height: 0.95;
    }

    .product-price-main {
      color: var(--rivano-brown);
      font-family: var(--font-sans);
      font-size: 21px;
      font-weight: 400;
      line-height: 1.2;
    }

    .product-microcopy,
    .purchase-support {
      color: color-mix(in srgb, var(--rivano-brown) 66%, transparent);
      font-family: var(--font-sans);
      font-size: 14px;
      font-weight: 300;
      line-height: 1.7;
      max-width: 360px;
    }

    .product-availability {
      color: color-mix(in srgb, var(--rivano-brown) 62%, transparent);
      font-family: var(--font-sans);
      font-size: 10px;
      letter-spacing: 0.12em;
      line-height: 1.4;
      text-transform: uppercase;
    }

    .product-availability::before {
      background: currentColor;
      border-radius: 50%;
      content: "";
      display: inline-block;
      height: 6px;
      margin-right: 8px;
      vertical-align: 1px;
      width: 6px;
    }

    .product-availability.is-unavailable {
      color: color-mix(in srgb, var(--rivano-brown) 38%, transparent);
    }

    .panel-label {
      color: var(--rivano-brown);
      font-family: var(--font-sans);
      font-size: 10px;
      font-weight: 400;
      letter-spacing: 0.1em;
      line-height: 1.4;
      margin-bottom: 10px;
      text-transform: uppercase;
    }

    .variant-options {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .variant-option {
      align-items: center;
      background: transparent;
      border: 1px solid color-mix(in srgb, var(--rivano-brown) 18%, transparent);
      color: var(--rivano-brown);
      cursor: pointer;
      display: inline-flex;
      font-family: var(--font-sans);
      font-size: 11px;
      gap: 8px;
