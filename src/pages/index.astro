---
import ProductCard from "../components/ProductCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { formatPriceBRL, toCardProduct, type Product } from "../lib/products";
import productsData from "../data/products.json";

const allProducts = productsData as Product[];
const editorialProducts = allProducts.slice(0, 4).map(toCardProduct);
const secondaryProducts = allProducts.slice(6, 10).map(toCardProduct);

const testimonials = [
  {
    quote: "Óculos perfeitos, chegaram rápido e a qualidade surpreendeu.",
    name: "Mariana R.",
    city: "Salvador",
  },
  {
    quote: "Comprei pelo WhatsApp, super fácil. Adoro o design.",
    name: "Pedro A.",
    city: "São Paulo",
  },
  {
    quote: "Já é o segundo par que compro. Não troco por nada.",
    name: "Camila S.",
    city: "Recife",
  },
];
---

<BaseLayout
  title="Rivano | Óculos premium para dias de sol"
  description="Óculos premium-acessíveis da Rivano. Design autoral, verão europeu e compra pelo WhatsApp."
  showAnnouncementBar={false}
  showBottomBar={false}
>
  <div class="rivano-home">
    <section class="campaign-hero" aria-label="Campanha Rivano verão 2025">
      <video class="campaign-video" src="/banners/hero.mov" autoplay muted loop playsinline></video>
      <div class="campaign-gradient" aria-hidden="true"></div>
      <div class="campaign-content">
        <p class="campaign-kicker">Rivano 2025</p>
        <h1 class="campaign-title">Verão no olhar.</h1>
        <div class="campaign-actions" aria-label="Ações da campanha">
          <a class="campaign-cta campaign-cta--primary" href="/catalogo">Ver coleção</a>
          <a
            class="campaign-cta campaign-cta--secondary"
            href="https://wa.me/5571993135522"
            target="_blank"
            rel="noopener noreferrer"
          >
            WhatsApp
          </a>
        </div>
      </div>
    </section>

    <section class="post-hero-editorial" aria-label="Editorial Rivano">
      <div class="post-hero-inner">
        <div class="post-hero-image-wrap">
          <img src="/editorial/verao.png" alt="Óculos Rivano em composição de verão" class="post-hero-image" loading="eager" decoding="async" />
        </div>
        <div class="post-hero-copy">
          <p class="post-hero-label">Editorial</p>
          <h2 class="post-hero-title">Óculos para viver o verão.</h2>
          <p class="post-hero-text">Uma coleção pensada para luz, pele, mar e cidade.</p>
          <nav class="post-hero-links" aria-label="Coleções editoriais">
            <a href="/catalogo?para=ela">Ela</a>
            <a href="/catalogo?para=ele">Ele</a>
            <a href="/catalogo">Todos</a>
          </nav>
        </div>
      </div>
    </section>

    <section class="editorial-products" aria-labelledby="selecao-rivano">
      <div class="editorial-products-header">
        <p class="selection-label">Seleção Rivano</p>
        <h2 id="selecao-rivano" class="selection-title">O verão permanece.</h2>
        <p class="selection-text">Modelos feitos para acompanhar a luz, a cidade e os dias sem pressa.</p>
      </div>
      <div class="editorial-products-track">
        {
          editorialProducts.map((product, index) => (
            <a class="editorial-product" href={`/produtos/${product.slug}`} aria-label={`Ver ${product.name}`}>
              <span class="editorial-product-frame">
                <img
                  class="editorial-product-image"
                  src={product.image}
                  alt={product.name}
                  loading={index === 0 ? "eager" : "lazy"}
                  decoding="async"
                />
              </span>
              <span class="editorial-product-name">{product.name}</span>
              <span class="editorial-product-price">{formatPriceBRL(product.price)}</span>
            </a>
          ))
        }
      </div>
      <div class="editorial-products-link-wrap">
        <a class="editorial-text-link" href="/catalogo">Ver catálogo</a>
      </div>
    </section>

    <section class="sun-curation" aria-label="Curadoria Rivano">
      <div class="sun-curation-inner">
        <article class="sun-curation-item sun-curation-item--dela">
          <div class="sun-curation-image-wrap">
            <img src="/editorial/ela.png" alt="Mulher com lenço usando óculos Rivano sob céu azul" class="sun-curation-image" loading="lazy" decoding="async" />
          </div>
          <div class="sun-curation-copy">
            <p class="curation-label">Curadoria</p>
            <h2 class="curation-title">Sol dela</h2>
            <p class="curation-text">Frames leves para dias longos, luz bonita e presença sem esforço.</p>
            <a class="curation-link" href="/catalogo?para=ela">Ver seleção</a>
          </div>
        </article>

        <article class="sun-curation-item sun-curation-item--dele">
          <div class="sun-curation-image-wrap">
            <img src="/editorial/ele.png" alt="Homem usando óculos redondo Rivano em close sob céu azul" class="sun-curation-image" loading="lazy" decoding="async" />
          </div>
          <div class="sun-curation-copy">
            <p class="curation-label">Curadoria</p>
            <h2 class="curation-title">Sol dele</h2>
            <p class="curation-text">Linhas limpas, lentes marcantes e o verão como estado de espírito.</p>
            <a class="curation-link" href="/catalogo?para=ele">Ver seleção</a>
          </div>
        </article>
      </div>
    </section>

    <section class="pullquote-section" aria-label="Citação Rivano">
      <div class="pullquote-inner">
        <span class="pullquote-mark" aria-hidden="true">"</span>
        <blockquote class="display-md pullquote-text">
          Óculos não são acessório. São a primeira coisa que o mundo vê em você.
        </blockquote>
        <p class="pullquote-author">— Rivano</p>
      </div>
    </section>

    <section class="summer-split" aria-label="O espírito Rivano">
      <div class="summer-image-wrap">
        <img src="/editorial/verao.png" alt="Óculos na areia com bolsa de palha e laranja" class="summer-image" loading="lazy" decoding="async" />
      </div>
      <div class="summer-copy">
        <p class="section-label">O espírito Rivano</p>
        <h2 class="display-md summer-title">Feita para o sol.<br />Inspirada no verão europeu.</h2>
        <p class="summer-body">Da Riviera Francesa às praias do Brasil, um design que viaja com você.</p>
        <a class="home-button home-button--dark" href="#">Conhecer a marca</a>
      </div>
    </section>

    <section class="product-section product-section--secondary" aria-label="Mais produtos Rivano">
      <div class="secondary-grid">
        {
          secondaryProducts.map((product, index) => (
            <article class="home-product-card">
              <ProductCard product={product} index={index + 6} />
            </article>
          ))
        }
      </div>
    </section>

    <section class="testimonials-section" aria-labelledby="depoimentos">
      <h2 id="depoimentos" class="display-sm testimonials-title">O que dizem sobre nós</h2>
      <div class="testimonials-track">
        {
          testimonials.map((testimonial) => (
            <article class="testimonial-card">
              <div class="testimonial-stars" aria-label="5 estrelas">
                {Array.from({ length: 5 }).map(() => (
                  <svg class="star-icon" viewBox="0 0 24 24" aria-hidden="true">
                    <path
                      fill="currentColor"
                      d="m12 2.6 2.88 5.84 6.45.94-4.66 4.54 1.1 6.42L12 17.3l-5.77 3.04 1.1-6.42-4.66-4.54 6.45-.94L12 2.6Z"
                    />
                  </svg>
                ))}
              </div>
              <p class="testimonial-quote">"{testimonial.quote}"</p>
              <p class="testimonial-name">{testimonial.name}</p>
              <p class="testimonial-city">{testimonial.city}</p>
            </article>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .rivano-home {
    background: var(--rivano-off-white);
    color: var(--rivano-brown);
    overflow-x: hidden;
  }

  .campaign-hero {
    background: color-mix(in srgb, var(--rivano-brown) 86%, black);
    height: 100svh;
    margin-top: -60px;
    overflow: hidden;
    position: relative;
    width: 100vw;
  }

  .campaign-video {
    display: block;
    height: 100%;
    object-fit: cover;
    width: 100vw;
  }

  .campaign-gradient {
    background: linear-gradient(
      0deg,
      color-mix(in srgb, black 66%, transparent) 0%,
      color-mix(in srgb, var(--rivano-brown) 42%, transparent) 52%,
      transparent 100%
    );
    bottom: 0;
    height: 42%;
    left: 0;
    pointer-events: none;
    position: absolute;
    right: 0;
  }

  .campaign-content {
    bottom: 0;
    left: 0;
    padding: 24px;
    position: absolute;
    width: 100%;
    z-index: 1;
  }

  .campaign-kicker,
  .post-hero-label,
  .selection-label,
  .curation-label,
  .section-label,
  .pullquote-author,
  .testimonial-name {
    font-family: var(--font-sans);
    font-weight: 400;
    text-transform: uppercase;
  }

  .campaign-kicker {
    color: color-mix(in srgb, var(--rivano-off-white) 70%, transparent);
    font-size: 11px;
    letter-spacing: 0.16em;
    line-height: 1.35;
    margin-bottom: 12px;
  }

  .campaign-title {
    color: var(--rivano-off-white);
    font-family: var(--font-serif);
    font-size: clamp(56px, 16vw, 76px);
    font-weight: 300;
    letter-spacing: 0;
    line-height: 0.88;
    margin: 0;
    max-width: 320px;
  }

  .campaign-actions {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 8px 20px;
    margin-top: 24px;
  }

  .campaign-cta {
    align-items: center;
    color: var(--rivano-off-white);
    display: inline-flex;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 400;
    justify-content: center;
    letter-spacing: 0.14em;
    line-height: 1.2;
    min-height: 44px;
    text-transform: uppercase;
  }

  .campaign-cta--primary {
    border: 1px solid color-mix(in srgb, var(--rivano-off-white) 72%, transparent);
    padding: 0 22px;
  }

  .campaign-cta--primary:hover {
    background: color-mix(in srgb, var(--rivano-off-white) 12%, transparent);
  }

  .campaign-cta--secondary {
    opacity: 0.7;
    padding: 0;
  }

  .post-hero-editorial {
    background: var(--rivano-off-white);
  }

  .post-hero-image-wrap {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    width: 100%;
  }

  .post-hero-image {
    display: block;
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .post-hero-copy {
    padding: 32px 24px 48px;
  }

  .post-hero-label {
    color: var(--rivano-muted);
    font-size: 10px;
    letter-spacing: 0.18em;
    line-height: 1.35;
  }

  .post-hero-title {
    color: var(--rivano-brown);
    font-family: var(--font-serif);
    font-size: clamp(38px, 11vw, 56px);
    font-weight: 300;
    letter-spacing: 0;
    line-height: 0.95;
    margin-top: 14px;
    max-width: 340px;
  }

  .post-hero-text {
    color: color-mix(in srgb, var(--rivano-brown) 62%, transparent);
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 300;
    line-height: 1.65;
    margin-top: 16px;
    max-width: 320px;
  }

  .post-hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0 20px;
    margin-top: 24px;
  }

  .post-hero-links a {
    align-items: center;
    border-bottom: 1px solid currentColor;
    color: var(--rivano-brown);
    display: inline-flex;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.14em;
    line-height: 1.2;
    min-height: 44px;
    text-transform: uppercase;
  }

  .home-button {
    align-items: center;
    background: transparent;
    border: 1px solid currentColor;
    border-radius: 0;
    display: inline-flex;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 400;
    justify-content: center;
    letter-spacing: 0.12em;
    line-height: 1.2;
    min-height: 44px;
    padding: 14px 28px;
    text-transform: uppercase;
    transition: var(--transition-normal);
  }

  .home-button--dark {
    color: var(--rivano-brown);
  }

  .home-button--dark:hover {
    background: var(--rivano-brown);
    color: var(--rivano-off-white);
  }

  .editorial-products {
    background: var(--rivano-off-white);
    padding: 56px 0 64px;
  }

  .editorial-products-header {
    margin-bottom: 28px;
    padding: 0 24px;
  }

  .selection-label {
    color: var(--rivano-muted);
    font-size: 10px;
    letter-spacing: 0.18em;
    line-height: 1.35;
  }

  .selection-title {
    color: var(--rivano-brown);
    font-family: var(--font-serif);
    font-size: clamp(42px, 12vw, 62px);
    font-weight: 300;
    letter-spacing: 0;
    line-height: 0.92;
    margin-top: 12px;
    max-width: 360px;
  }

  .selection-text {
    color: color-mix(in srgb, var(--rivano-brown) 62%, transparent);
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 300;
    line-height: 1.65;
    margin-top: 16px;
    max-width: 320px;
  }

  .editorial-products-track {
    display: flex;
    gap: 14px;
    overflow-x: auto;
    padding: 0 24px;
    scrollbar-width: none;
    scroll-snap-type: x mandatory;
  }

  .editorial-products-track::-webkit-scrollbar {
    display: none;
  }

  .editorial-product {
    color: var(--rivano-brown);
    flex: 0 0 72vw;
    min-height: 44px;
    min-width: 0;
    scroll-snap-align: start;
  }

  .editorial-product-frame {
    align-items: center;
    aspect-ratio: 3 / 4;
    background: color-mix(in srgb, var(--rivano-beige) 45%, var(--rivano-off-white));
    display: flex;
    justify-content: center;
    overflow: hidden;
    width: 100%;
  }

  .editorial-product-image {
    display: block;
    height: 100%;
    object-fit: contain;
    padding: 8px;
    transform: scale(1.08);
    transition: opacity var(--transition-normal), transform var(--transition-slow);
    width: 100%;
  }

  .editorial-product:hover .editorial-product-image {
    opacity: 0.92;
    transform: scale(1.1);
  }

  .editorial-product-name {
    display: block;
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 300;
    letter-spacing: 0;
    line-height: 1.08;
    margin-top: 12px;
  }

  .editorial-product-price {
    color: var(--rivano-muted);
    display: block;
    font-family: var(--font-sans);
    font-size: 13px;
    font-weight: 300;
    line-height: 1.35;
    margin-top: 4px;
  }

  .editorial-products-link-wrap {
    margin: 28px 24px 0;
  }

  .editorial-text-link,
  .curation-link {
    align-items: center;
    border-bottom: 1px solid currentColor;
    color: var(--rivano-brown);
    display: inline-flex;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.14em;
    line-height: 1.2;
    min-height: 44px;
    text-transform: uppercase;
  }

  .sun-curation {
    background: var(--rivano-beige);
  }

  .sun-curation-item {
    border-top: 1px solid color-mix(in srgb, var(--rivano-off-white) 62%, transparent);
  }

  .sun-curation-item:first-child {
    border-top: 0;
  }

  .sun-curation-image-wrap {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    width: 100%;
  }

  .sun-curation-image,
  .summer-image {
    display: block;
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .sun-curation-copy {
    padding: 28px 24px 56px;
  }

  .curation-label {
    color: color-mix(in srgb, var(--rivano-brown) 45%, transparent);
    font-size: 10px;
    letter-spacing: 0.18em;
    line-height: 1.35;
  }

  .curation-title {
    color: var(--rivano-brown);
    font-family: var(--font-serif);
    font-size: clamp(46px, 13vw, 68px);
    font-weight: 300;
    letter-spacing: 0;
    line-height: 0.9;
    margin-top: 10px;
  }

  .curation-text {
    color: color-mix(in srgb, var(--rivano-brown) 62%, transparent);
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 300;
    line-height: 1.65;
    margin-top: 14px;
    max-width: 320px;
  }

  .curation-link {
    margin-top: 20px;
  }

  .section-label {
    color: color-mix(in srgb, var(--rivano-brown) 50%, transparent);
    font-size: 10px;
    letter-spacing: 0.16em;
    line-height: 1.35;
  }

  .product-section {
    background: var(--rivano-off-white);
    padding: 48px 16px;
  }

  .testimonials-title {
    font-family: var(--font-serif);
    font-weight: 300;
    margin: 0 auto 32px;
    text-align: center;
  }

  .secondary-grid {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin: 0 auto;
    max-width: 1280px;
    width: 100%;
  }

  .home-product-card :global(.image-container > span) {
    display: none;
  }

  .home-product-card :global(.product-info h3) {
    color: var(--rivano-brown);
    font-family: var(--font-serif);
    font-size: 16px;
    font-weight: 400;
    letter-spacing: 0;
    line-height: 1.15;
  }

  .home-product-card :global(.price) {
    color: color-mix(in srgb, var(--rivano-brown) 58%, transparent);
    font-family: var(--font-sans);
    font-size: 13px;
  }

  .pullquote-section {
    background: var(--rivano-brown);
    color: var(--rivano-off-white);
    overflow: hidden;
  }

  .pullquote-inner {
    margin: 0 auto;
    padding: 64px 32px;
    position: relative;
  }

  .pullquote-mark {
    color: color-mix(in srgb, var(--rivano-gold) 12%, transparent);
    font-family: var(--font-serif);
    font-size: 180px;
    font-weight: 300;
    left: 16px;
    line-height: 1;
    pointer-events: none;
    position: absolute;
    top: -20px;
  }

  .pullquote-text {
    color: var(--rivano-off-white);
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 300;
    margin: 0 auto;
    max-width: 680px;
    position: relative;
    text-align: center;
  }

  .pullquote-author {
    color: color-mix(in srgb, var(--rivano-off-white) 40%, transparent);
    font-size: 10px;
    letter-spacing: 0.16em;
    line-height: 1.4;
    margin-top: 24px;
    position: relative;
    text-align: center;
  }

  .summer-split {
    background: var(--rivano-off-white);
  }

  .summer-image-wrap {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    width: 100%;
  }

  .summer-copy {
    padding: 32px 24px;
  }

  .summer-copy .section-label {
    color: color-mix(in srgb, var(--rivano-brown) 45%, transparent);
  }

  .summer-title {
    font-family: var(--font-serif);
    font-weight: 300;
    margin-top: 12px;
  }

  .summer-body {
    color: color-mix(in srgb, var(--rivano-brown) 65%, transparent);
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 300;
    line-height: 1.75;
    margin-top: 16px;
    max-width: 380px;
  }

  .summer-copy .home-button {
    margin-top: 24px;
  }

  .product-section--secondary {
    background: var(--rivano-beige);
  }

  .testimonials-section {
    background: var(--rivano-beige);
    padding: 48px 0;
  }

  .testimonials-title {
    padding: 0 24px;
  }

  .testimonials-track {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    padding: 0 24px;
    scrollbar-width: none;
    scroll-snap-type: x mandatory;
  }

  .testimonials-track::-webkit-scrollbar {
    display: none;
  }

  .testimonial-card {
    background: var(--rivano-off-white);
    flex: 0 0 82vw;
    flex-shrink: 0;
    min-width: 0;
    padding: 28px;
    scroll-snap-align: start;
  }

  .testimonial-stars {
    color: var(--rivano-gold);
    display: flex;
    gap: 3px;
  }

  .star-icon {
    height: 11px;
    width: 11px;
  }

  .testimonial-quote {
    color: var(--rivano-brown);
    font-family: var(--font-serif);
    font-size: 18px;
    font-style: italic;
    font-weight: 300;
    line-height: 1.65;
    margin-top: 14px;
    overflow-wrap: break-word;
  }

  .testimonial-name {
    color: color-mix(in srgb, var(--rivano-brown) 55%, transparent);
    font-size: 10px;
    letter-spacing: 0.1em;
    line-height: 1.35;
    margin-top: 18px;
  }

  .testimonial-city {
    color: color-mix(in srgb, var(--rivano-brown) 35%, transparent);
    font-family: var(--font-sans);
    font-size: 10px;
    line-height: 1.35;
    margin-top: 2px;
  }

  @media (min-width: 768px) {
    .campaign-hero {
      height: 100vh;
      margin-top: -90px;
    }

    .campaign-content {
      padding: 40px;
    }

    .campaign-title {
      font-size: clamp(72px, 9vw, 128px);
      max-width: 560px;
    }

    .post-hero-editorial {
      padding: 96px 40px;
    }

    .post-hero-inner {
      display: grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      margin: 0 auto;
      max-width: 1440px;
    }

    .post-hero-image-wrap {
      grid-column: 1 / 8;
    }

    .post-hero-copy {
      align-self: center;
      grid-column: 8 / 13;
      padding: 0 0 0 56px;
    }

    .post-hero-title {
      font-size: clamp(52px, 5vw, 86px);
      max-width: 520px;
    }

    .editorial-products {
