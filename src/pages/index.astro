---
import ProductCard from "../components/ProductCard.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { toCardProduct, type Product } from "../lib/products";
import productsData from "../data/products.json";

const allProducts = productsData as Product[];
const featuredProducts = allProducts.slice(0, 6).map(toCardProduct);
const secondaryProducts = allProducts.slice(6, 10).map(toCardProduct);

const testimonials = [
  {
    quote: "Óculos perfeitos, chegaram rápido e a qualidade surpreendeu.",
    name: "Mariana R.",
    city: "Salvador",
  },
  {
    quote: "Comprei pelo WhatsApp, super fácil. Adoro o design.",
    name: "Pedro A.",
    city: "São Paulo",
  },
  {
    quote: "Já é o segundo par que compro. Não troco por nada.",
    name: "Camila S.",
    city: "Recife",
  },
];
---

<BaseLayout
  title="Rivano | Óculos premium para dias de sol"
  description="Óculos premium-acessíveis da Rivano. Design autoral, verão europeu e compra pelo WhatsApp."
>
  <div class="rivano-home">
    <section class="hero-video" aria-label="Rivano coleção 2025">
      <div class="hero-frame">
        <video class="hero-media" src="/banners/hero.mov" autoplay muted loop playsinline></video>
        <div class="hero-gradient" aria-hidden="true"></div>
        <div class="hero-content">
          <h1 class="display-xl hero-title">Olhar que define.</h1>
          <p class="hero-kicker">Coleção 2025</p>
          <a class="home-button home-button--light" href="/catalogo">Ver coleção</a>
          <a class="hero-whatsapp-link" href="https://wa.me/5571993135522" aria-label="Fale com a Rivano pelo WhatsApp">
            <svg class="hero-whatsapp-icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.67-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.076 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421-7.403h-.004a9.87 9.87 0 00-4.995 1.348l-.36-.183L2.702 2.56l.855 3.081A9.857 9.857 0 002.5 12c0 5.471 4.585 9.905 10.007 9.905 2.716 0 5.274-.869 7.422-2.49l.362.187 3.099 1.006-.893-3.222a9.9 9.9 0 001.449-5.393c0-5.471-4.585-9.905-10.007-9.905z" />
            </svg>
            Fale com a gente
          </a>
        </div>
      </div>
    </section>

    <section class="trust-section" aria-label="Confiança Rivano">
      <div class="trust-bar">
        <span class="trust-compact-item"><span aria-hidden="true">↻</span><span>Troca 30 dias</span></span>
        <span class="trust-separator" aria-hidden="true">·</span>
        <span class="trust-compact-item"><span aria-hidden="true">✓</span><span>100% Original</span></span>
        <span class="trust-separator" aria-hidden="true">·</span>
        <span class="trust-compact-item"><span aria-hidden="true">💬</span><span>WhatsApp 24h</span></span>
      </div>
    </section>

    <section class="intro-editorial" aria-label="Manifesto Rivano">
      <div class="intro-inner">
        <p class="display-md intro-title">Feitos para quem vive ao sol.</p>
        <p class="intro-subtitle">Design autoral. Qualidade real. Preço honesto.</p>
      </div>
    </section>

    <section class="collection-highlight" aria-label="Destaques de coleção">
      <article class="collection-block collection-block--ela">
        <div class="collection-image-wrap">
          <img src="/editorial/ela.png" alt="Mulher com lenço usando óculos Rivano sob céu azul" class="collection-image" loading="eager" decoding="async" />
        </div>
        <div class="collection-copy">
          <p class="section-label">Coleção</p>
          <h2 class="display-lg collection-title">Ela</h2>
          <p class="collection-description">Frames que acompanham cada mood. Do café da manhã à hora dourada.</p>
          <a class="home-button home-button--dark" href="/catalogo?genero=ela">Ver coleção</a>
        </div>
      </article>

      <hr class="collection-separator" />

      <article class="collection-block collection-block--ele">
        <div class="collection-copy">
          <p class="section-label">Coleção</p>
          <h2 class="display-lg collection-title">Ele</h2>
          <p class="collection-description">Linhas precisas, presença garantida. Para quem sabe o que quer.</p>
          <a class="home-button home-button--dark" href="/catalogo?genero=ele">Ver coleção</a>
        </div>
        <div class="collection-image-wrap">
          <img src="/editorial/ele.png" alt="Homem usando óculos redondo Rivano em close sob céu azul" class="collection-image" loading="lazy" decoding="async" />
        </div>
      </article>
    </section>

    <section class="product-section product-section--featured" aria-labelledby="mais-vistos">
      <h2 id="mais-vistos" class="display-sm product-section-title">Mais vistos</h2>
      <div class="featured-grid">
        {
          featuredProducts.map((product, index) => (
            <article class:list={["home-product-card", index % 3 === 1 && "home-product-card--offset"]}>
              <ProductCard product={product} index={index} />
            </article>
          ))
        }
      </div>
      <div class="catalog-link-wrap">
        <a class="home-button home-button--dark" href="/catalogo">Ver catálogo completo</a>
      </div>
    </section>

    <section class="pullquote-section" aria-label="Citação Rivano">
      <div class="pullquote-inner">
        <span class="pullquote-mark" aria-hidden="true">"</span>
        <blockquote class="display-md pullquote-text">
          Óculos não são acessório. São a primeira coisa que o mundo vê em você.
        </blockquote>
        <p class="pullquote-author">— Rivano</p>
      </div>
    </section>

    <section class="summer-split" aria-label="O espírito Rivano">
      <div class="summer-image-wrap">
        <img src="/editorial/verao.png" alt="Óculos na areia com bolsa de palha e laranja" class="summer-image" loading="lazy" decoding="async" />
      </div>
      <div class="summer-copy">
        <p class="section-label">O espírito Rivano</p>
        <h2 class="display-md summer-title">Feita para o sol.<br />Inspirada no verão europeu.</h2>
        <p class="summer-body">Da Riviera Francesa às praias do Brasil, um design que viaja com você.</p>
        <a class="home-button home-button--dark" href="#">Conhecer a marca</a>
      </div>
    </section>

    <section class="product-section product-section--secondary" aria-label="Mais produtos Rivano">
      <div class="secondary-grid">
        {
          secondaryProducts.map((product, index) => (
            <article class="home-product-card">
              <ProductCard product={product} index={index + 6} />
            </article>
          ))
        }
      </div>
    </section>

    <section class="testimonials-section" aria-labelledby="depoimentos">
      <h2 id="depoimentos" class="display-sm testimonials-title">O que dizem sobre nós</h2>
      <div class="testimonials-track">
        {
          testimonials.map((testimonial) => (
            <article class="testimonial-card">
              <div class="testimonial-stars" aria-label="5 estrelas">
                {Array.from({ length: 5 }).map(() => (
                  <svg class="star-icon" viewBox="0 0 24 24" aria-hidden="true">
                    <path
                      fill="currentColor"
                      d="m12 2.6 2.88 5.84 6.45.94-4.66 4.54 1.1 6.42L12 17.3l-5.77 3.04 1.1-6.42-4.66-4.54 6.45-.94L12 2.6Z"
                    />
                  </svg>
                ))}
              </div>
              <p class="testimonial-quote">"{testimonial.quote}"</p>
              <p class="testimonial-name">{testimonial.name}</p>
              <p class="testimonial-city">{testimonial.city}</p>
            </article>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .rivano-home {
    background: var(--rivano-off-white);
    color: var(--rivano-brown);
    overflow-x: hidden;
  }

  .hero-video {
    background: var(--rivano-off-white);
    width: 100%;
  }

  .hero-frame {
    height: 90vh;
    margin: 0;
    overflow: hidden;
    position: relative;
    width: 100vw;
  }

  .hero-media {
    display: block;
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .hero-gradient {
    background: linear-gradient(0deg, color-mix(in srgb, var(--rivano-brown) 72%, transparent) 0%, transparent 100%);
    bottom: 0;
    height: 45%;
    left: 0;
    position: absolute;
    right: 0;
  }

  .hero-content {
    bottom: 0;
    left: 0;
    padding: 24px 24px 88px;
    position: absolute;
    width: 100%;
  }

  .hero-title {
    color: var(--rivano-off-white);
    font-family: var(--font-serif);
    font-weight: 300;
    max-width: 340px;
  }

  .hero-kicker,
  .intro-subtitle,
  .section-label,
  .pullquote-author,
  .trust-title,
  .testimonial-name {
    font-family: var(--font-sans);
    font-weight: 400;
    text-transform: uppercase;
  }

  .hero-kicker {
    color: color-mix(in srgb, var(--rivano-off-white) 70%, transparent);
    font-size: 12px;
    letter-spacing: 0.14em;
    line-height: 1.35;
    margin-top: 12px;
  }

  .home-button {
    align-items: center;
    background: transparent;
    border: 1px solid currentColor;
    border-radius: 0;
    display: inline-flex;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 400;
    justify-content: center;
    letter-spacing: 0.12em;
    line-height: 1.2;
    min-height: 44px;
    padding: 14px 28px;
    text-transform: uppercase;
    transition: var(--transition-normal);
  }

  .home-button--light {
    color: var(--rivano-off-white);
    margin-top: 24px;
  }

  .home-button--light:hover {
    background: var(--rivano-off-white);
    color: var(--rivano-brown);
  }

  .home-button--dark {
    color: var(--rivano-brown);
  }

  .home-button--dark:hover {
    background: var(--rivano-brown);
    color: var(--rivano-off-white);
  }

  .hero-whatsapp-link {
    align-items: center;
    color: color-mix(in srgb, var(--rivano-off-white) 70%, transparent);
    display: inline-flex;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 400;
    gap: 8px;
    letter-spacing: 0.1em;
    line-height: 1.2;
    margin-top: 12px;
    min-height: 44px;
    text-transform: uppercase;
  }

  .hero-whatsapp-icon {
    height: 14px;
    width: 14px;
  }

  .intro-editorial {
    background: var(--rivano-off-white);
    padding: 48px 24px;
    text-align: center;
  }

  .intro-inner {
    margin: 0 auto;
  }

  .intro-title {
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 300;
  }

  .intro-subtitle {
    color: color-mix(in srgb, var(--rivano-brown) 55%, transparent);
    font-size: 12px;
    letter-spacing: 0.16em;
    line-height: 1.6;
    margin-top: 16px;
  }

  .collection-highlight {
    background: var(--rivano-beige);
    padding: 0 0 48px;
  }

  .collection-image-wrap {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    width: 100%;
  }

  .collection-image,
  .summer-image {
    display: block;
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .collection-copy {
    padding: 28px 24px;
  }

  .section-label {
    color: color-mix(in srgb, var(--rivano-brown) 50%, transparent);
    font-size: 10px;
    letter-spacing: 0.16em;
    line-height: 1.35;
  }

  .collection-title {
    font-family: var(--font-serif);
    font-weight: 300;
    margin-top: 10px;
  }

  .collection-description {
    color: color-mix(in srgb, var(--rivano-brown) 65%, transparent);
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 300;
    line-height: 1.65;
    margin-top: 12px;
    max-width: 360px;
  }

  .collection-copy .home-button {
    margin-top: 24px;
  }

  .collection-separator {
    border: 0;
    border-top: 1px solid var(--rivano-off-white);
    margin: 0 24px;
  }

  .product-section {
    background: var(--rivano-off-white);
    padding: 48px 16px;
  }

  .product-section-title,
  .testimonials-title {
    font-family: var(--font-serif);
    font-weight: 300;
    margin: 0 auto 32px;
    text-align: center;
  }

  .featured-grid,
  .secondary-grid {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    margin: 0 auto;
    max-width: 1280px;
    width: 100%;
  }

  .home-product-card :global(.image-container > span) {
    display: none;
  }

  .home-product-card :global(.product-info h3) {
    color: var(--rivano-brown);
    font-family: var(--font-serif);
    font-size: 16px;
    font-weight: 400;
    letter-spacing: 0;
    line-height: 1.15;
  }

  .home-product-card :global(.price) {
    color: color-mix(in srgb, var(--rivano-brown) 58%, transparent);
    font-family: var(--font-sans);
    font-size: 13px;
  }

  .catalog-link-wrap {
    display: flex;
    justify-content: center;
    margin-top: 32px;
  }

  .pullquote-section {
    background: var(--rivano-brown);
    color: var(--rivano-off-white);
    overflow: hidden;
  }

  .pullquote-inner {
    margin: 0 auto;
    padding: 64px 32px;
    position: relative;
  }

  .pullquote-mark {
    color: color-mix(in srgb, var(--rivano-gold) 12%, transparent);
    font-family: var(--font-serif);
    font-size: 180px;
    font-weight: 300;
    left: 16px;
    line-height: 1;
    pointer-events: none;
    position: absolute;
    top: -20px;
  }

  .pullquote-text {
    color: var(--rivano-off-white);
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 300;
    margin: 0 auto;
    max-width: 680px;
    position: relative;
    text-align: center;
  }

  .pullquote-author {
    color: color-mix(in srgb, var(--rivano-off-white) 40%, transparent);
    font-size: 10px;
    letter-spacing: 0.16em;
    line-height: 1.4;
    margin-top: 24px;
    position: relative;
    text-align: center;
  }

  .summer-split {
    background: var(--rivano-off-white);
  }

  .summer-image-wrap {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    width: 100%;
  }

  .summer-copy {
    padding: 32px 24px;
  }

  .summer-copy .section-label {
    color: color-mix(in srgb, var(--rivano-brown) 45%, transparent);
  }

  .summer-title {
    font-family: var(--font-serif);
    font-weight: 300;
    margin-top: 12px;
  }

  .summer-body {
    color: color-mix(in srgb, var(--rivano-brown) 65%, transparent);
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 300;
    line-height: 1.75;
    margin-top: 16px;
    max-width: 380px;
  }

  .summer-copy .home-button {
    margin-top: 24px;
  }

  .product-section--secondary {
    background: var(--rivano-beige);
  }

  .trust-section {
    background: var(--rivano-beige);
    padding: 32px 24px;
  }

  .trust-bar {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 14px 32px;
    justify-content: center;
  }

  .trust-compact-item {
    align-items: center;
    color: var(--rivano-brown);
    display: inline-flex;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 400;
    gap: 8px;
    letter-spacing: 0.1em;
    line-height: 1.35;
    text-transform: uppercase;
  }

  .trust-separator {
    color: var(--rivano-muted);
    font-size: 11px;
    line-height: 1;
  }

  .testimonials-section {
    background: var(--rivano-beige);
    padding: 48px 0;
  }

  .testimonials-title {
    padding: 0 24px;
  }

  .testimonials-track {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    padding: 0 24px;
    scrollbar-width: none;
    scroll-snap-type: x mandatory;
  }

  .testimonials-track::-webkit-scrollbar {
    display: none;
  }

  .testimonial-card {
    background: var(--rivano-off-white);
    flex: 0 0 82vw;
    flex-shrink: 0;
    min-width: 0;
    padding: 28px;
    scroll-snap-align: start;
  }

  .testimonial-stars {
    color: var(--rivano-gold);
    display: flex;
    gap: 3px;
  }

  .star-icon {
    height: 11px;
    width: 11px;
  }

  .testimonial-quote {
    color: var(--rivano-brown);
    font-family: var(--font-serif);
    font-size: 18px;
    font-style: italic;
    font-weight: 300;
    line-height: 1.65;
    margin-top: 14px;
    overflow-wrap: break-word;
  }

  .testimonial-name {
    color: color-mix(in srgb, var(--rivano-brown) 55%, transparent);
    font-size: 10px;
    letter-spacing: 0.1em;
    line-height: 1.35;
    margin-top: 18px;
  }

  .testimonial-city {
    color: color-mix(in srgb, var(--rivano-brown) 35%, transparent);
    font-family: var(--font-sans);
    font-size: 10px;
    line-height: 1.35;
    margin-top: 2px;
  }

  @media (min-width: 768px) {
    .hero-frame {
      height: 100vh;
      margin: 0 auto;
      width: 100%;
    }

    .hero-content {
      padding: 24px 24px 156px;
    }

    .hero-whatsapp-link {
      display: none;
    }

    .intro-editorial {
      padding: 128px 24px;
    }

    .intro-inner {
      max-width: 640px;
    }

    .collection-highlight {
      padding: 96px 40px;
    }

    .collection-block {
      display: grid;
      gap: 0;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      margin: 0 auto;
      max-width: 1280px;
    }

    .collection-block--ela .collection-image-wrap {
      grid-column: 1 / 8;
    }

    .collection-block--ela .collection-copy {
      grid-column: 8 / 13;
      padding: 0 0 0 48px;
    }

    .collection-block--ele {
      margin-top: 64px;
    }

    .collection-block--ele .collection-copy {
      grid-column: 1 / 6;
      grid-row: 1;
      padding: 0 48px 0 0;
    }

    .collection-block--ele .collection-image-wrap {
      grid-column: 6 / 13;
      grid-row: 1;
    }

    .collection-copy {
      align-self: center;
    }

    .collection-separator {
      display: none;
    }

    .product-section--featured {
      padding: 96px 40px;
    }

    .featured-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .home-product-card--offset {
      padding-top: 56px;
    }

    .pullquote-inner {
      max-width: 680px;
      padding: 128px 40px;
    }

    .summer-split {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
      padding: 96px 40px;
    }

    .summer-copy {
      align-self: center;
      padding: 0 0 0 64px;
    }

    .product-section--secondary {
      padding: 64px 40px;
    }

    .secondary-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .trust-section {
      padding: 40px;
    }

    .trust-bar {
      gap: 64px;
    }

    .testimonials-section {
      padding: 96px 40px;
    }

    .testimonials-track {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      margin: 0 auto;
      max-width: 1280px;
      overflow: visible;
      padding: 0;
    }

    .testimonial-card {
      flex: initial;
      min-width: 0;
    }
  }
</style>
