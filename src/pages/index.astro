---
import BaseLayout from "../layouts/BaseLayout.astro";
import { formatPriceBRL, toCardProduct, type Product } from "../lib/products";
import productsData from "../data/products.json";

const allProducts = productsData as Product[];
const editorialProducts = allProducts.slice(0, 4).map(toCardProduct);
const secondaryProducts = allProducts.slice(6, 10).map(toCardProduct);

const testimonials = [
  {
    quote: "Óculos perfeitos, chegaram rápido e a qualidade surpreendeu.",
    name: "Mariana R.",
    city: "Salvador",
  },
  {
    quote: "Comprei pelo WhatsApp, super fácil. Adoro o design.",
    name: "Pedro A.",
    city: "São Paulo",
  },
  {
    quote: "Já é o segundo par que compro. Não troco por nada.",
    name: "Camila S.",
    city: "Recife",
  },
];
---

<BaseLayout
  title="Rivano | Óculos premium para dias de sol"
  description="Óculos premium-acessíveis da Rivano. Design autoral, verão europeu e compra pelo WhatsApp."
  showAnnouncementBar={false}
  showBottomBar={false}
>
  <div class="rivano-home">
    <section class="campaign-hero" aria-label="Campanha Rivano verão 2025">
      <video class="campaign-video" src="/banners/hero.mov" autoplay muted loop playsinline></video>
      <div class="campaign-gradient" aria-hidden="true"></div>
      <div class="campaign-content">
        <p class="campaign-kicker">Rivano 2025</p>
        <h1 class="campaign-title">Verão no olhar.</h1>
        <div class="campaign-actions" aria-label="Ações da campanha">
          <a class="campaign-cta campaign-cta--primary" href="/catalogo">Ver coleção</a>
          <a
            class="campaign-cta campaign-cta--secondary"
            href="https://wa.me/5571993135522"
            target="_blank"
            rel="noopener noreferrer"
          >
            WhatsApp
          </a>
        </div>
      </div>
    </section>

    <section class="post-hero-editorial" aria-label="Editorial Rivano">
      <div class="post-hero-inner">
        <div class="post-hero-image-wrap">
          <img src="/editorial/verao.png" alt="Óculos Rivano em composição de verão" class="post-hero-image" loading="eager" decoding="async" />
        </div>
        <div class="post-hero-copy">
          <p class="post-hero-label">Editorial</p>
          <h2 class="post-hero-title">Óculos para viver o verão.</h2>
          <p class="post-hero-text">Uma coleção pensada para luz, pele, mar e cidade.</p>
          <nav class="post-hero-links" aria-label="Coleções editoriais">
            <a href="/catalogo?para=ela">Ela</a>
            <a href="/catalogo?para=ele">Ele</a>
            <a href="/catalogo">Todos</a>
          </nav>
        </div>
      </div>
    </section>

    <section class="editorial-products" aria-labelledby="selecao-rivano">
      <div class="editorial-products-header">
        <p class="selection-label">Seleção Rivano</p>
        <h2 id="selecao-rivano" class="selection-title">O verão permanece.</h2>
        <p class="selection-text">Modelos feitos para acompanhar a luz, a cidade e os dias sem pressa.</p>
      </div>
      <div class="editorial-products-track">
        {
          editorialProducts.map((product, index) => (
            <a class="editorial-product" href={`/produtos/${product.slug}`} aria-label={`Ver ${product.name}`}>
              <span class="editorial-product-frame">
                <img
                  class="editorial-product-image"
                  src={product.image}
                  alt={product.name}
                  loading={index === 0 ? "eager" : "lazy"}
                  decoding="async"
                />
              </span>
              <span class="editorial-product-name">{product.name}</span>
              <span class="editorial-product-price">{formatPriceBRL(product.price)}</span>
            </a>
          ))
        }
      </div>
      <div class="editorial-products-link-wrap">
        <a class="editorial-text-link" href="/catalogo">Ver catálogo</a>
      </div>
    </section>

    <section class="sun-curation" aria-label="Curadoria Rivano">
      <div class="sun-curation-inner">
        <article class="sun-curation-item sun-curation-item--dela">
          <div class="sun-curation-image-wrap">
            <img src="/editorial/ela.png" alt="Mulher com lenço usando óculos Rivano sob céu azul" class="sun-curation-image" loading="lazy" decoding="async" />
          </div>
          <div class="sun-curation-copy">
            <p class="curation-label">Curadoria</p>
            <h2 class="curation-title">Sol dela</h2>
            <p class="curation-text">Frames leves para dias longos, luz bonita e presença sem esforço.</p>
            <a class="curation-link" href="/catalogo?para=ela">Ver seleção</a>
          </div>
        </article>

        <article class="sun-curation-item sun-curation-item--dele">
          <div class="sun-curation-image-wrap">
            <img src="/editorial/ele.png" alt="Homem usando óculos redondo Rivano em close sob céu azul" class="sun-curation-image" loading="lazy" decoding="async" />
          </div>
          <div class="sun-curation-copy">
            <p class="curation-label">Curadoria</p>
            <h2 class="curation-title">Sol dele</h2>
            <p class="curation-text">Linhas limpas, lentes marcantes e o verão como estado de espírito.</p>
            <a class="curation-link" href="/catalogo?para=ele">Ver seleção</a>
          </div>
        </article>
      </div>
    </section>

    <section class="manifesto-section" aria-label="Manifesto Rivano">
      <div class="manifesto-inner">
        <p class="manifesto-label">Manifesto</p>
        <h2 class="manifesto-title">O verão permanece.</h2>
        <p class="manifesto-text">Na pele, na luz, no olhar.</p>
        <p class="manifesto-signature">Rivano</p>
      </div>
    </section>

    <section class="brand-story-section" aria-label="O espírito Rivano">
      <div class="brand-story-inner">
        <div class="brand-story-copy">
          <p class="brand-story-label">O espírito Rivano</p>
          <h2 class="brand-story-title">Feita para o sol que fica.</h2>
          <p class="brand-story-text">Da cidade à beira-mar, a Rivano traduz o verão como presença: leve, elegante e impossível de apressar.</p>
          <a class="brand-story-link" href="/catalogo">Conhecer a marca</a>
        </div>
      </div>
    </section>

    <section class="latest-rays-section" aria-labelledby="ultimos-raios">
      <div class="latest-rays-header">
        <p class="latest-rays-label">Curadoria Rivano</p>
        <h2 id="ultimos-raios" class="display-md latest-rays-title">Últimos raios</h2>
        <p class="latest-rays-subtitle">Armações escolhidas para acompanhar a luz até o fim do dia.</p>
      </div>
      <div class="latest-rays-track">
        {
          secondaryProducts.map((product, index) => (
            <a class="latest-ray-item" href={`/produtos/${product.slug}`} aria-label={`Ver ${product.name}`}>
              <span class="latest-ray-frame">
                <img
                  class="latest-ray-image"
                  src={product.image}
                  alt={product.name}
                  loading={index === 0 ? "eager" : "lazy"}
                  decoding="async"
                />
              </span>
              <span class="latest-ray-name">{product.name}</span>
              <span class="latest-ray-price">{formatPriceBRL(product.price)}</span>
            </a>
          ))
        }
      </div>
      <a class="latest-rays-link" href="/catalogo">Ver catálogo completo</a>
    </section>

    <section class="social-proof-section" aria-labelledby="depoimentos">
      <div class="social-proof-header">
        <p class="social-proof-label">Prova social</p>
        <h2 id="depoimentos" class="display-md social-proof-title">O que fica depois do sol</h2>
        <p class="social-proof-subtitle">Relatos de quem encontrou na Rivano um par para todos os dias de verão.</p>
      </div>
      <div class="social-proof-track">
        {
          testimonials.map((testimonial) => (
            <article class="social-proof-card">
              <div class="social-proof-stars" aria-label="5 estrelas">
                {Array.from({ length: 5 }).map(() => (
                  <svg class="star-icon" viewBox="0 0 24 24" aria-hidden="true">
                    <path
                      fill="currentColor"
                      d="m12 2.6 2.88 5.84 6.45.94-4.66 4.54 1.1 6.42L12 17.3l-5.77 3.04 1.1-6.42-4.66-4.54 6.45-.94L12 2.6Z"
                    />
                  </svg>
                ))}
              </div>
              <p class="social-proof-quote">"{testimonial.quote}"</p>
              <p class="social-proof-name">{testimonial.name}</p>
              <p class="social-proof-city">{testimonial.city}</p>
            </article>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .rivano-home {
    background: var(--rivano-off-white);
    color: var(--rivano-brown);
    overflow-x: hidden;
  }

  .campaign-hero {
    background: color-mix(in srgb, var(--rivano-brown) 86%, black);
    height: calc(100svh - 60px);
    overflow: hidden;
    position: relative;
    width: 100vw;
  }

  .campaign-video {
    display: block;
    height: 100%;
    object-fit: cover;
    width: 100vw;
  }

  .campaign-gradient {
    background: linear-gradient(
      0deg,
      color-mix(in srgb, black 66%, transparent) 0%,
      color-mix(in srgb, var(--rivano-brown) 42%, transparent) 52%,
      transparent 100%
    );
    bottom: 0;
    height: 42%;
    left: 0;
    pointer-events: none;
    position: absolute;
    right: 0;
  }

  .campaign-content {
    bottom: 0;
    left: 0;
    padding: 24px 24px calc(32px + env(safe-area-inset-bottom));
    position: absolute;
    width: 100%;
    z-index: 1;
  }

  .campaign-kicker,
  .post-hero-label,
  .selection-label,
  .curation-label,
  .manifesto-label,
  .manifesto-text,
  .manifesto-signature,
  .brand-story-label,
  .social-proof-name {
    font-family: var(--font-sans);
    font-weight: 400;
    text-transform: uppercase;
  }

  .campaign-kicker {
    color: color-mix(in srgb, var(--rivano-off-white) 70%, transparent);
    font-size: 11px;
    letter-spacing: 0.16em;
    line-height: 1.35;
    margin-bottom: 12px;
  }

  .campaign-title {
    color: var(--rivano-off-white);
    font-family: var(--font-serif);
    font-size: clamp(56px, 16vw, 76px);
    font-weight: 300;
    letter-spacing: 0;
    line-height: 0.88;
    margin: 0;
    max-width: 320px;
  }

  .campaign-actions {
    align-items: center;
    display: flex;
    flex-wrap: wrap;
    gap: 8px 20px;
    margin-top: 24px;
  }

  .campaign-cta {
    align-items: center;
    color: var(--rivano-off-white);
    display: inline-flex;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 400;
    justify-content: center;
    letter-spacing: 0.14em;
    line-height: 1.2;
    min-height: 44px;
    text-transform: uppercase;
  }

  .campaign-cta--primary {
    border: 1px solid color-mix(in srgb, var(--rivano-off-white) 72%, transparent);
    padding: 0 22px;
  }

  .campaign-cta--primary:hover {
    background: color-mix(in srgb, var(--rivano-off-white) 12%, transparent);
  }

  .campaign-cta--secondary {
    opacity: 0.7;
    padding: 0;
  }

  .post-hero-editorial {
    background: var(--rivano-off-white);
  }

  .post-hero-image-wrap {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    width: 100%;
  }

  .post-hero-image {
    display: block;
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .post-hero-copy {
    padding: 32px 24px 48px;
  }

  .post-hero-label {
    color: var(--rivano-muted);
    font-size: 10px;
    letter-spacing: 0.18em;
    line-height: 1.35;
  }

  .post-hero-title {
    color: var(--rivano-brown);
    font-family: var(--font-serif);
    font-size: clamp(38px, 11vw, 56px);
    font-weight: 300;
    letter-spacing: 0;
    line-height: 0.95;
    margin-top: 14px;
    max-width: 340px;
  }

  .post-hero-text {
    color: color-mix(in srgb, var(--rivano-brown) 62%, transparent);
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 300;
    line-height: 1.65;
    margin-top: 16px;
    max-width: 320px;
  }

  .post-hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0 20px;
    margin-top: 24px;
  }

  .post-hero-links a {
    align-items: center;
    border-bottom: 1px solid currentColor;
    color: var(--rivano-brown);
    display: inline-flex;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.14em;
    line-height: 1.2;
    min-height: 44px;
    text-transform: uppercase;
  }

  .editorial-products {
    background: var(--rivano-off-white);
    padding: 56px 0 64px;
  }

  .editorial-products-header {
    margin-bottom: 28px;
    padding: 0 24px;
  }

  .selection-label {
    color: var(--rivano-muted);
    font-size: 10px;
    letter-spacing: 0.18em;
    line-height: 1.35;
  }

  .selection-title {
    color: var(--rivano-brown);
    font-family: var(--font-serif);
    font-size: clamp(42px, 12vw, 62px);
    font-weight: 300;
    letter-spacing: 0;
    line-height: 0.92;
    margin-top: 12px;
    max-width: 360px;
  }

  .selection-text {
    color: color-mix(in srgb, var(--rivano-brown) 62%, transparent);
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 300;
    line-height: 1.65;
    margin-top: 16px;
    max-width: 320px;
  }

  .editorial-products-track {
    display: flex;
    gap: 14px;
    overflow-x: auto;
    padding: 0 24px;
    scrollbar-width: none;
    scroll-snap-type: x mandatory;
  }

  .editorial-products-track::-webkit-scrollbar {
    display: none;
  }

  .editorial-product {
    color: var(--rivano-brown);
    flex: 0 0 70vw;
    min-height: 44px;
    min-width: 0;
    scroll-snap-align: start;
  }

  .editorial-product-frame {
    align-items: center;
    aspect-ratio: 1 / 1;
    background: color-mix(in srgb, var(--rivano-off-white) 74%, var(--rivano-beige));
    border: 1px solid color-mix(in srgb, var(--rivano-beige) 60%, var(--rivano-off-white));
    border-radius: 8px;
    display: flex;
    justify-content: center;
    overflow: hidden;
    padding: 24px;
    width: 100%;
  }

  .editorial-product-image {
    display: block;
    filter: contrast(1.03) saturate(0.98);
    height: auto;
    mix-blend-mode: multiply;
    object-fit: contain;
    transition: opacity var(--transition-normal);
    width: auto;
    max-height: 42%;
    max-width: 68%;
  }

  .editorial-product:hover .editorial-product-image {
    opacity: 0.94;
  }

  .editorial-product-name {
    display: block;
    font-family: var(--font-serif);
    font-size: 17px;
    font-weight: 300;
    letter-spacing: 0;
    line-height: 1.12;
    margin-top: 11px;
  }

  .editorial-product-price {
    color: color-mix(in srgb, var(--rivano-brown) 56%, transparent);
    display: block;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 300;
    line-height: 1.35;
    margin-top: 4px;
  }

  .editorial-products-link-wrap {
    margin: 28px 24px 0;
  }

  .editorial-text-link,
  .curation-link {
    align-items: center;
    border-bottom: 1px solid currentColor;
    color: var(--rivano-brown);
    display: inline-flex;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.14em;
    line-height: 1.2;
    min-height: 44px;
    text-transform: uppercase;
  }

  .sun-curation {
    background: var(--rivano-beige);
  }

  .sun-curation-item {
    border-top: 1px solid color-mix(in srgb, var(--rivano-off-white) 62%, transparent);
  }

  .sun-curation-item:first-child {
    border-top: 0;
  }

  .sun-curation-image-wrap {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    width: 100%;
  }

  .sun-curation-image {
    display: block;
    height: 100%;
    object-fit: cover;
    width: 100%;
  }

  .sun-curation-copy {
    padding: 28px 24px 56px;
  }

  .curation-label {
    color: color-mix(in srgb, var(--rivano-brown) 45%, transparent);
    font-size: 10px;
    letter-spacing: 0.18em;
    line-height: 1.35;
  }

  .curation-title {
    color: var(--rivano-brown);
    font-family: var(--font-serif);
    font-size: clamp(46px, 13vw, 68px);
    font-weight: 300;
    letter-spacing: 0;
    line-height: 0.9;
    margin-top: 10px;
  }

  .curation-text {
    color: color-mix(in srgb, var(--rivano-brown) 62%, transparent);
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 300;
    line-height: 1.65;
    margin-top: 14px;
    max-width: 320px;
  }

  .curation-link {
    margin-top: 20px;
  }

  .latest-rays-section {
    background: var(--rivano-off-white);
    padding: 64px 0;
  }

  .latest-rays-header {
    margin-bottom: 32px;
    padding: 0 24px;
  }

  .latest-rays-label {
    color: color-mix(in srgb, var(--rivano-brown) 45%, transparent);
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.16em;
    line-height: 1.35;
    text-transform: uppercase;
  }

  .latest-rays-title {
    color: var(--rivano-brown);
    font-family: var(--font-serif);
    font-weight: 300;
    letter-spacing: 0;
    margin-top: 12px;
    max-width: 560px;
  }

  .latest-rays-subtitle {
    color: color-mix(in srgb, var(--rivano-brown) 60%, transparent);
    font-family: var(--font-sans);
    font-size: 14px;
    font-weight: 300;
    line-height: 1.7;
    margin-top: 16px;
    max-width: 360px;
  }

  .latest-rays-track {
    display: flex;
    gap: 14px;
    overflow-x: auto;
    padding: 0 24px;
    scrollbar-width: none;
    scroll-snap-type: x mandatory;
  }

  .latest-rays-track::-webkit-scrollbar {
    display: none;
  }

  .latest-ray-item {
    color: var(--rivano-brown);
    display: block;
    flex: 0 0 70vw;
    min-width: 0;
    scroll-snap-align: start;
  }

  .latest-ray-item:nth-child(2) {
    margin-top: 32px;
  }

  .latest-ray-item:nth-child(4) {
    margin-top: 16px;
  }

  .latest-ray-frame {
    align-items: center;
    aspect-ratio: 1 / 1;
    background: color-mix(in srgb, var(--rivano-off-white) 74%, var(--rivano-beige));
    border: 1px solid color-mix(in srgb, var(--rivano-beige) 60%, var(--rivano-off-white));
    border-radius: 8px;
    display: flex;
    justify-content: center;
    overflow: hidden;
    padding: 24px;
    width: 100%;
  }

  .latest-ray-image {
    display: block;
    filter: contrast(1.03) saturate(0.98);
    height: auto;
    mix-blend-mode: multiply;
    object-fit: contain;
    width: auto;
    max-height: 42%;
    max-width: 68%;
  }

  .latest-ray-name {
    color: var(--rivano-brown);
    display: block;
    font-family: var(--font-serif);
    font-size: 17px;
    font-weight: 300;
    letter-spacing: 0;
    line-height: 1.12;
    margin-top: 11px;
  }

  .latest-ray-price {
    color: color-mix(in srgb, var(--rivano-brown) 56%, transparent);
    display: block;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 300;
    line-height: 1.35;
    margin-top: 4px;
  }

  .latest-rays-link {
    align-items: center;
    border-bottom: 1px solid currentColor;
    color: var(--rivano-brown);
    display: inline-flex;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.12em;
    line-height: 1.2;
    margin: 32px 0 0 24px;
    min-height: 44px;
    text-transform: uppercase;
  }

  .manifesto-section {
    background: var(--rivano-brown);
    color: var(--rivano-off-white);
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-height: 72svh;
    padding: 72px 24px;
  }

  .manifesto-label {
    color: color-mix(in srgb, var(--rivano-off-white) 52%, transparent);
    font-size: 10px;
    letter-spacing: 0.18em;
    line-height: 1.35;
  }

  .manifesto-title {
    color: var(--rivano-off-white);
    font-family: var(--font-serif);
    font-size: clamp(64px, 19vw, 96px);
    font-weight: 300;
    letter-spacing: 0;
    line-height: 0.82;
    margin-top: 20px;
    max-width: 360px;
  }

  .manifesto-text {
    color: color-mix(in srgb, var(--rivano-off-white) 62%, transparent);
    font-size: 12px;
    letter-spacing: 0.16em;
    line-height: 1.6;
    margin-top: 28px;
    max-width: 260px;
  }

  .manifesto-signature {
    color: color-mix(in srgb, var(--rivano-off-white) 42%, transparent);
    font-size: 10px;
    letter-spacing: 0.18em;
    line-height: 1.35;
    margin-top: 72px;
  }

  .brand-story-section {
    background: var(--rivano-off-white);
    padding: 72px 24px;
  }

  .brand-story-copy {
    max-width: 360px;
  }

  .brand-story-label {
    color: var(--rivano-muted);
    font-size: 10px;
    letter-spacing: 0.18em;
    line-height: 1.35;
  }

  .brand-story-title {
    color: var(--rivano-brown);
    font-family: var(--font-serif);
    font-size: clamp(44px, 12vw, 68px);
    font-weight: 300;
    letter-spacing: 0;
    line-height: 0.92;
    margin-top: 12px;
    max-width: 340px;
  }

